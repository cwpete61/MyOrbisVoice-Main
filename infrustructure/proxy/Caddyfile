{
  auto_https off
}

:80 {
  @app host app.localhost
  handle @app {
    reverse_proxy app-web:3000
  }

  @api host api.localhost
  handle @api {
    reverse_proxy app-api:4000
  }

  @n8n host n8n.localhost
  handle @n8n {
    reverse_proxy n8n-main:5678
  }

  handle {
    respond "VoiceAutomation local proxy is running." 200
  }
}
