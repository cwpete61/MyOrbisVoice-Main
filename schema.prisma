generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  ARCHIVED
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PromptScope {
  PLATFORM
  TENANT
  CHANNEL
  ROLE
  CAMPAIGN
}

enum PromptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ChannelType {
  WIDGET
  INBOUND
  OUTBOUND
}

enum AgentRoleType {
  ORCHESTRATOR
  APPOINTMENT
  SALES
  CUSTOMER_SERVICE
  MARKETING
  ASSISTANT
  SECRETARY
}

enum IntegrationProvider {
  GOOGLE
  TWILIO
  STRIPE
  TRANSACTIONAL_EMAIL
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
  RECONNECT_REQUIRED
  DISABLED
}

enum ConversationDirection {
  INBOUND
  OUTBOUND
  WIDGET
}

enum ConversationStatus {
  OPEN
  COMPLETED
  FAILED
  ESCALATED
  ABANDONED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULED
  CANCELED
  FAILED
}

enum MessageChannel {
  EMAIL
  SMS
  VOICE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  PAUSED
  DISABLED
}

enum CommissionStatus {
  PENDING
  APPROVED
  HOLD
  PAID
  REVERSED
}

enum AuditActorType {
  USER
  ADMIN
  SYSTEM
  WORKFLOW
}

enum SecretOwnerType {
  PLATFORM
  TENANT
  USER
  INTEGRATION
}

enum EntitlementValueType {
  BOOLEAN
  INTEGER
  STRING
}

enum EntitlementSourceType {
  PLAN
  ADMIN_OVERRIDE
  PROMOTION
  MANUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum RotationStatus {
  VALID
  NEEDS_ROTATION
  REVOKED
  UNKNOWN
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELED
}

enum WidgetSessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  EXPIRED
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  username               String?                @unique
  passwordHash           String
  firstName              String?
  lastName               String?
  status                 UserStatus             @default(ACTIVE)
  lastLoginAt            DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tenantMemberships      TenantMember[]
  createdPromptVersions  PromptVersion[]        @relation("PromptCreatedBy")
  auditLogs              AuditLog[]             @relation("AuditActorUser")
  affiliateAccount       AffiliateAccount?
  startedImpersonations  ImpersonationSession[] @relation("ImpersonationStartedBy")
  refreshTokens          RefreshToken[]
}

model Tenant {
  id                     String                  @id @default(uuid())
  slug                   String                  @unique
  displayName            String
  legalName              String?
  status                 TenantStatus            @default(TRIAL)
  timezone               String                  @default("America/New_York")
  registrationEmail      String
  publicEmail            String?
  publicPhone            String?
  website                String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  members                TenantMember[]
  businessProfile        BusinessProfile?
  businessDNARecords     BusinessDNA[]
  promptVersions         PromptVersion[]
  agentProfiles          AgentProfile[]
  channelConfigs         ChannelConfig[]
  integrationConnections IntegrationConnection[]
  stripeCustomerRef      StripeCustomerRef?
  subscriptions          Subscription[]
  phoneNumbers           PhoneNumber[]
  contacts               Contact[]
  conversations          Conversation[]
  appointments           Appointment[]
  messageLogs            MessageLog[]
  workflowExecutions     WorkflowExecutionRef[]
  tenantEntitlements     TenantEntitlement[]
  affiliateConversions   AffiliateConversion[]
  affiliateCommissions   AffiliateCommission[]
  auditLogs              AuditLog[]
  impersonationSessions  ImpersonationSession[]
  callLogs               CallLog[]
  outboundCampaigns      OutboundCampaign[]
  outboundCallAttempts   OutboundCallAttempt[]
  widgetSessions         WidgetSession[]
}

model TenantMember {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String
  roleDefinitionId String
  isOwner          Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  @@unique([tenantId, userId])
}

model RoleDefinition {
  id            String         @id @default(uuid())
  key           String         @unique
  name          String
  description   String?
  isPlatformRole Boolean       @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantMembers TenantMember[]
}

model Plan {
  id              String            @id @default(uuid())
  code            String            @unique
  name            String
  description     String?
  interval        PlanInterval
  stripePriceId   String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entitlements    PlanEntitlement[]
  subscriptions   Subscription[]
}

model PlanEntitlement {
  id           String               @id @default(uuid())
  planId       String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  plan         Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
}

model TenantEntitlement {
  id           String               @id @default(uuid())
  tenantId      String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  sourceType   EntitlementSourceType
  sourceRef    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model BusinessProfile {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  brandName               String
  logoUrl                 String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  region                  String?
  postalCode              String?
  country                 String?
  serviceAreasJson        Json?
  businessHoursJson       Json?
  fallbackNotificationEmail String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessDNA {
  id             String   @id @default(uuid())
  tenantId       String
  identityJson   Json
  servicesJson   Json
  pricingJson    Json
  operationsJson Json
  salesJson      Json
  appointmentJson Json
  supportJson    Json
  languageJson   Json
  complianceJson Json
  version        Int
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
}

model PromptVersion {
  id             String         @id @default(uuid())
  tenantId       String?
  scope          PromptScope
  channelType    ChannelType?
  agentRoleType  AgentRoleType?
  name           String
  content        String
  status         PromptStatus   @default(DRAFT)
  versionNumber  Int            @default(1)
  parentPromptId String?
  createdByUserId String?
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentPrompt   PromptVersion? @relation("PromptParent", fields: [parentPromptId], references: [id], onDelete: SetNull)
  childPrompts   PromptVersion[] @relation("PromptParent")
  createdByUser  User?          @relation("PromptCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  agentProfiles  AgentProfile[]
  channelConfigs ChannelConfig[]

  @@index([tenantId, scope])
  @@index([tenantId, status])
}

model AgentProfile {
  id             String        @id @default(uuid())
  tenantId       String
  agentRoleType  AgentRoleType
  displayName    String
  isEnabled      Boolean       @default(false)
  modelProvider  String
  modelName      String
  promptVersionId String?
  settingsJson   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion  PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, agentRoleType])
}

model ChannelConfig {
  id              String         @id @default(uuid())
  tenantId        String
  channelType     ChannelType
  isEnabled       Boolean        @default(false)
  publicKey       String?        @unique
  greetingMode    String?
  afterHoursMode  String?
  escalationMode  String?
  configJson      Json?
  promptVersionId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, channelType])
}

model IntegrationConnection {
  id                  String                 @id @default(uuid())
  tenantId            String?
  provider            IntegrationProvider
  status              IntegrationStatus      @default(NOT_CONNECTED)
  label               String
  externalAccountId   String?
  externalEmail       String?
  metadataJson        Json?
  lastVerifiedAt      DateTime?
  reconnectRequiredAt DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tenant              Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  googleDetail        GoogleConnectionDetail?
  twilioDetail        TwilioConnectionDetail?
}

model GoogleConnectionDetail {
  id                     String               @id @default(uuid())
  integrationConnectionId String             @unique
  mailboxEmail           String
  grantedScopesJson      Json
  calendarIdsJson        Json?
  tokenExpiresAt         DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  integrationConnection  IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model TwilioConnectionDetail {
  id                     String               @id @default(uuid())
  integrationConnectionId String             @unique
  accountSid             String
  encryptedAuthToken     String?
  messagingServiceSid    String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  integrationConnection  IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model StripeCustomerRef {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
}

model PhoneNumber {
  id               String   @id @default(uuid())
  tenantId         String
  twilioNumberSid  String?
  e164Number       String   @unique
  displayLabel     String?
  isInboundEnabled Boolean  @default(false)
  isOutboundEnabled Boolean @default(false)
  isSmsEnabled     Boolean  @default(false)
  forwardingTarget String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Contact {
  id               String          @id @default(uuid())
  tenantId         String
  firstName        String?
  lastName         String?
  fullName         String?
  email            String?
  phoneE164        String?
  source           String
  tagsJson         Json?
  metadataJson     Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations    Conversation[]
  appointments     Appointment[]
  messageLogs      MessageLog[]
  callLogs         CallLog[]
  outboundAttempts OutboundCallAttempt[]

  @@index([tenantId, email])
  @@index([tenantId, phoneE164])
}

model Conversation {
  id              String                 @id @default(uuid())
  tenantId        String
  contactId       String?
  channelType     ChannelType
  direction       ConversationDirection
  status          ConversationStatus
  startedAt       DateTime
  endedAt         DateTime?
  summaryText     String?
  transcriptRef   String?
  outcomeCode     String?
  outcomeJson     Json?
  externalCallId  String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  appointments    Appointment[]
  messageLogs     MessageLog[]
  callLogs        CallLog[]

  @@index([tenantId, startedAt])
  @@index([tenantId, channelType])
  @@index([externalCallId])
}

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String
  contactId       String?
  conversationId  String?
  status          AppointmentStatus
  appointmentType String?
  startAt         DateTime
  endAt           DateTime
  timezone        String
  providerEventId String?
  location        String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation    Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}

model MessageLog {
  id                String            @id @default(uuid())
  tenantId          String
  contactId         String?
  conversationId    String?
  channel           MessageChannel
  direction         MessageDirection
  sender            String
  recipient         String
  subject           String?
  bodyRef           String?
  providerMessageId String?
  deliveryStatus    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact           Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation      Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}

model CallLog {
  id               String      @id @default(uuid())
  tenantId         String
  contactId        String?
  conversationId   String?
  direction        ConversationDirection
  sourceNumber     String
  destinationNumber String
  providerCallId   String?     @unique
  status           String
  startAt          DateTime?
  endAt            DateTime?
  durationSeconds  Int?
  forwarded        Boolean     @default(false)
  forwardingTarget String?
  outcomeCode      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
}

model WorkflowExecutionRef {
  id            String                  @id @default(uuid())
  tenantId      String?
  workflowCode  String
  executionRef  String
  status        WorkflowExecutionStatus
  inputHash     String?
  resultJson    Json?
  startedAt     DateTime
  finishedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  tenant        Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([workflowCode, executionRef])
}

model AffiliateAccount {
  id              String               @id @default(uuid())
  userId          String               @unique
  status          AffiliateStatus      @default(PENDING)
  referralCode    String               @unique
  payoutMethodJson Json?
  taxProfileJson  Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks          AffiliateClick[]
  conversions     AffiliateConversion[]
  commissions     AffiliateCommission[]
}

model AffiliateClick {
  id                String           @id @default(uuid())
  affiliateAccountId String
  tenantId          String?
  sessionId         String?
  landingPath       String?
  referrer          String?
  ipHash            String?
  userAgent         String?
  createdAt         DateTime         @default(now())
  affiliateAccount  AffiliateAccount @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)

  @@index([affiliateAccountId, createdAt])
}

model AffiliateConversion {
  id                String           @id @default(uuid())
  affiliateAccountId String
  tenantId          String
  subscriptionId    String?
  conversionType    String
  conversionValue   Int?
  occurredAt        DateTime
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  affiliateAccount  AffiliateAccount @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commissions       AffiliateCommission[]
}

model AffiliateCommission {
  id                   String            @id @default(uuid())
  affiliateConversionId String
  affiliateAccountId   String
  tenantId             String
  amountMinor          Int
  currency             String
  status               CommissionStatus  @default(PENDING)
  approvedAt           DateTime?
  paidAt               DateTime?
  payoutRef            String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  affiliateConversion  AffiliateConversion @relation(fields: [affiliateConversionId], references: [id], onDelete: Cascade)
  affiliateAccount     AffiliateAccount  @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([affiliateAccountId, status])
}

model AuditLog {
  id                    String                @id @default(uuid())
  tenantId              String?
  actorType             AuditActorType
  actorUserId           String?
  impersonationSessionId String?
  action                String
  targetType            String
  targetId              String?
  metadataJson          Json?
  ipHash                String?
  createdAt             DateTime              @default(now())
  tenant                Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser             User?                 @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  impersonationSession  ImpersonationSession? @relation(fields: [impersonationSessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model SecretRef {
  id              String          @id @default(uuid())
  ownerType       SecretOwnerType
  ownerId         String
  secretType      String
  label           String
  provider        String
  externalRef     String?
  lastValidatedAt DateTime?
  rotationStatus  RotationStatus  @default(UNKNOWN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([ownerType, ownerId, secretType, label])
}

model ImpersonationSession {
  id              String    @id @default(uuid())
  adminUserId     String
  tenantId        String
  assumedRoleKey  String
  reasonCode      String?
  notes           String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  adminUser       User      @relation("ImpersonationStartedBy", fields: [adminUserId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]

  @@index([tenantId, startedAt])
  @@index([adminUserId, startedAt])
}

// Short-lived token issued to the browser widget before a voice session starts.
// The voice gateway verifies this token, then upgrades to a full session.
model WidgetSession {
  id              String              @id @default(uuid())
  tenantId        String
  contactId       String?
  token           String              @unique
  status          WidgetSessionStatus @default(PENDING)
  channelConfigId String?
  promptSnapshotJson Json?
  businessDNASnapshotJson Json?
  conversationId  String?
  remoteIp        String?
  userAgent       String?
  expiresAt       DateTime
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OutboundCampaign {
  id              String               @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  status          CampaignStatus       @default(DRAFT)
  audienceJson    Json?
  scheduleJson    Json?
  promptVersionId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attempts        OutboundCallAttempt[]
}

model OutboundCallAttempt {
  id                String            @id @default(uuid())
  campaignId        String
  tenantId          String
  contactId         String
  providerCallId    String?           @unique
  status            String
  attemptNumber     Int               @default(1)
  startedAt         DateTime?
  endedAt           DateTime?
  outcomeCode       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaign          OutboundCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact           Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
}

model SystemConfig {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}
