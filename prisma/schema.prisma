  spouseName           String?
  kidsInfoJson         Json? // [{ name, age?, birthday?, notes? }]
  petsInfoJson         Json? // [{ name, type, age?, notes? }]
  importantDatesJson   Json? // [{ label, date, notes? }] — arbitrary recurring dates
  hobbies              String? // freeform / comma-separated interests
