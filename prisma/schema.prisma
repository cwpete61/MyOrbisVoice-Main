// Short-lived token issued to the browser widget before a voice session starts.
// The voice gateway verifies this token, then upgrades to a full session.
model WidgetSession {
  id                      String              @id @default(uuid())
  tenantId                String
  contactId               String?
  token                   String              @unique
  status                  WidgetSessionStatus @default(PENDING)
  channelConfigId         String?
  promptSnapshotJson      Json?
  businessDNASnapshotJson Json?
  metadataJson            Json?
  conversationId          String?
  remoteIp                String?
  userAgent               String?
  expiresAt               DateTime
  startedAt               DateTime?
  endedAt                 DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  tenant                  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// One-time password-reset tokens. Created when a user requests a reset via
/// /forgot-password, consumed via /reset-password. Token sent in the email
/// is the raw bytes; what's stored here is sha256(raw) — same pattern as
/// RefreshToken so a DB leak doesn't compromise pending resets.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime // 15 minutes from createdAt — short TTL is the security gate
  usedAt    DateTime? // single-use; set when the token is redeemed
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OutboundCampaign {
