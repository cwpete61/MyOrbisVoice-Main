model Appointment {
  id              String            @id @default(uuid())
  tenantId        String
  contactId       String?
  conversationId  String?
  staffMemberId   String?
  // Phase E.2 — bookings originating from a partner's landing-page widget are
  // written to the partner's own Google Calendar, NOT the tenant's. The
  // tenantId stays set (the platform demo tenant owns the DB row for admin
  // visibility); partnerId identifies which partner's calendar holds the
  // matching Google event. Null on every non-partner-page appointment.
  partnerId       String?
  status          AppointmentStatus
  appointmentType String?
  startAt         DateTime
  endAt           DateTime
  timezone        String
  providerEventId String?
  location        String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation    Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  staffMember     StaffMember?      @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  partner         AffiliateAccount? @relation("PartnerAppointments", fields: [partnerId], references: [id], onDelete: SetNull)
  reminders       AppointmentReminder[]

  @@index([partnerId])
}

// ─── Phase E.6 — Appointment reminders ──────────────────────────────────────
// Decoupled from the campaign system so reminders fire without requiring the
// tenant to configure a campaign. One row per (appointment, channel, offset).
// The reminder-runner job polls PENDING rows where scheduledAt <= now and
// dispatches through the existing email + SMS services. Offsets + channel
// toggles live on BusinessProfile so the tenant edits them in /settings.

enum ReminderChannel {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED  // appointment was cancelled or rescheduled before the reminder fired
}

model AppointmentReminder {
  id            String           @id @default(uuid())
  tenantId      String
  appointmentId String
  contactId     String
  channel       ReminderChannel
  offsetMin     Int              // minutes before appointment.startAt — kept for audit / debug
  scheduledAt   DateTime         // = appointment.startAt - offsetMin
  status        ReminderStatus   @default(PENDING)
  sentAt        DateTime?
  errorReason   String?
  attemptCount  Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment   Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, channel, offsetMin])  // one reminder per (channel, offset) per appointment
  @@index([status, scheduledAt])                  // scheduler hot path
  @@index([tenantId, scheduledAt])
}

model MessageLog {
