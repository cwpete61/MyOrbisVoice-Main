model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  username              String?                @unique
  passwordHash          String
  firstName             String?
  lastName              String?
  preferredLocale       String                 @default("en")
  status                UserStatus             @default(ACTIVE)
  lastLoginAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenantMemberships     TenantMember[]
  createdPromptVersions PromptVersion[]        @relation("PromptCreatedBy")
  auditLogs             AuditLog[]             @relation("AuditActorUser")
  affiliateAccount      AffiliateAccount?
  startedImpersonations ImpersonationSession[] @relation("ImpersonationStartedBy")
  refreshTokens         RefreshToken[]
  pushSubscriptions     PushSubscription[]
  a2pOperatorNotes      A2POperatorNote[]
  passwordResetTokens   PasswordResetToken[]
  uploadedKbFiles       KnowledgeBaseFile[]    @relation("KbFileUploadedBy")
}

model Tenant {
  id                        String                  @id @default(uuid())
  slug                      String                  @unique
  displayName               String
  legalName                 String?
  status                    TenantStatus            @default(TRIAL)
  timezone                  String                  @default("America/New_York")
  registrationEmail         String
  publicEmail               String?
  publicPhone               String?
  website                   String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  deletedAt                 DateTime?
  /// Per-step explicit "I'm done with this onboarding step" markers.
  /// Shape: { profile: true, dna: true, ... } — set by the user clicking
  /// the "Save & Back to Get Started" button on a step page. Acts as an
  /// override on top of the data-based auto-detection so a user who has
  /// configured what they care about can mark a step done even if
  /// non-required fields are blank. Null = nothing manually marked yet.
  onboardingMarkedDone      Json?
  referredByCode            String?
  attributedAt              DateTime?
  industryVertical          IndustryVertical        @default(GENERAL)
  members                   TenantMember[]
  businessProfile           BusinessProfile?
  businessDNARecords        BusinessDNA[]
  promptVersions            PromptVersion[]
  agentProfiles             AgentProfile[]
  channelConfigs            ChannelConfig[]
  integrationConnections    IntegrationConnection[]
  stripeCustomerRef         StripeCustomerRef?
  subscriptions             Subscription[]
  phoneNumbers              PhoneNumber[]
  twilioSubaccount          TenantTwilioSubaccount?
  a2pApplication            TenantA2PApplication?
  pushSubscriptions         PushSubscription[]
  contacts                  Contact[]
  conversations             Conversation[]
  appointments              Appointment[]
  staffMembers              StaffMember[]
  messageLogs               MessageLog[]
  workflowExecutions        WorkflowExecutionRef[]
  tenantEntitlements        TenantEntitlement[]
  affiliateConversions      AffiliateConversion[]
  affiliateCommissions      AffiliateCommission[]
  auditLogs                 AuditLog[]
  impersonationSessions     ImpersonationSession[]
  callLogs                  CallLog[]
  outboundCampaigns         OutboundCampaign[]
  outboundCallAttempts      OutboundCallAttempt[]
  campaigns                 Campaign[]
  campaignEnrollments       CampaignEnrollment[]
  widgetSessions            WidgetSession[]
  twilioEventLogs           TwilioEventLog[]
  storageQuotaBytes         BigInt?
  storageUsedBytes          BigInt                  @default(0)
  storageWarningAckedAt     DateTime?
  recordingBehavior         String                  @default("stop")
  recordingRetentionDays    Int?
  storageTier               String?
  storageGracePeriodEndsAt  DateTime?
  storagePreviousQuotaBytes BigInt?
  optOutLogs                OptOutLog[]
  notifications             Notification[]
  knowledgeBaseFiles        KnowledgeBaseFile[]
  /// Cumulative bytes used by knowledge-base files. Maintained by the
  /// upload/delete service. Capped by the `kb_storage_mb` entitlement
  /// (separate pool from voice-recording storageUsedBytes).
  kbStorageUsedBytes        BigInt                  @default(0)
}

model TenantMember {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String
  roleDefinitionId String
  isOwner          Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  @@unique([tenantId, userId])
}

model RoleDefinition {
  id             String         @id @default(uuid())
  key            String         @unique
  name           String
  description    String?
  isPlatformRole Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenantMembers  TenantMember[]
}

model Plan {
  id            String            @id @default(uuid())
  code          String            @unique
  name          String
  description   String?
  interval      PlanInterval
  priceCents    Int               @default(0)
  stripePriceId String?
  /// Optional second Stripe price ID, used for plans that bundle a one-time
  /// charge (`stripePriceId`) PLUS a recurring add-on (this field). Today
  /// only LTD uses this — $497 one-time for lifetime access plus $24.99/mo
  /// for token coverage. Standard plans leave this null.
  stripeRecurringPriceId String?
  /// Public Stripe Payment Link URL for this plan (https://buy.stripe.com/...).
  /// Used by the comp-codes admin page to give admins a one-click share link
  /// that the recipient can open to land directly in Stripe checkout with the
  /// right price loaded — `?prefilled_email=` and `?prefilled_promo_code=`
  /// query params are appended at link-generation time. Created via the
  /// Stripe API once per plan and reused.
  stripeBuyLinkUrl String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  entitlements  PlanEntitlement[]
  subscriptions Subscription[]
}

model PlanEntitlement {
  id           String               @id @default(uuid())
  planId       String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  plan         Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
}

model TenantEntitlement {
  id           String                @id @default(uuid())
  tenantId     String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  sourceType   EntitlementSourceType
  sourceRef    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model BusinessProfile {
  id                        String   @id @default(uuid())
  tenantId                  String   @unique
  brandName                 String
  logoUrl                   String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  region                    String?
  postalCode                String?
  country                   String?
  serviceAreasJson          Json?
  businessHoursJson         Json?
  fallbackNotificationEmail String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessDNA {
  id              String   @id @default(uuid())
  tenantId        String
  identityJson    Json
  servicesJson    Json
  pricingJson     Json
  operationsJson  Json
  salesJson       Json
  appointmentJson Json
  supportJson     Json
  languageJson    Json
  complianceJson  Json
  version         Int
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
}

/// Tenant-uploaded reference documents the AI agent can use as background
/// knowledge during conversations. File blobs live on Bunny under
/// `tenants/{tenantId}/knowledge-base/{id}.{ext}`. Extracted text lives in
/// this row's `extractedText` so the agent never round-trips to Bunny on
/// the live-call path. Capped per-tenant by the `kb_storage_mb`
/// entitlement; per-file size capped by KB_MAX_FILE_BYTES in code.
model KnowledgeBaseFile {
  id               String       @id @default(uuid())
  tenantId         String
  filename         String
  mimeType         String
  sizeBytes        Int
  bunnyStorageKey  String       @unique
  extractedText    String?
  extractionStatus KbFileStatus @default(PENDING)
  errorMessage     String?
  uploadedById     String
  uploadedAt       DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant     Tenant @relation(fields: [tenantId],     references: [id], onDelete: Cascade)
  uploadedBy User   @relation("KbFileUploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId, extractionStatus])
  @@index([tenantId, uploadedAt])
}

enum KbFileStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model PromptVersion {
  id              String          @id @default(uuid())
  tenantId        String?
  scope           PromptScope
  channelType     ChannelType?
  agentRoleType   AgentRoleType?
  name            String
  content         String
  status          PromptStatus    @default(DRAFT)
  versionNumber   Int             @default(1)
  parentPromptId  String?
  createdByUserId String?
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenant          Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentPrompt    PromptVersion?  @relation("PromptParent", fields: [parentPromptId], references: [id], onDelete: SetNull)
  childPrompts    PromptVersion[] @relation("PromptParent")
  createdByUser   User?           @relation("PromptCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  agentProfiles   AgentProfile[]
  channelConfigs  ChannelConfig[]

  @@index([tenantId, scope])
  @@index([tenantId, status])
}

model AgentProfile {
  id              String         @id @default(uuid())
  tenantId        String
  agentRoleType   AgentRoleType
  displayName     String
  isEnabled       Boolean        @default(false)
  modelProvider   String
  modelName       String
  promptVersionId String?
  settingsJson    Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, agentRoleType])
}

model ChannelConfig {
  id              String         @id @default(uuid())
  tenantId        String
  channelType     ChannelType
  isEnabled       Boolean        @default(false)
  publicKey       String?        @unique
  greetingMode    String?
  afterHoursMode  String?
  escalationMode  String?
  configJson      Json?
  promptVersionId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, channelType])
}

model IntegrationConnection {
  id                  String                  @id @default(uuid())
  tenantId            String?
  provider            IntegrationProvider
  status              IntegrationStatus       @default(NOT_CONNECTED)
  label               String
  externalAccountId   String?
  externalEmail       String?
  metadataJson        Json?
  lastVerifiedAt      DateTime?
  reconnectRequiredAt DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  googleDetail        GoogleConnectionDetail?
  twilioDetail        TwilioConnectionDetail?
  staffMember         StaffMember?
}

model GoogleConnectionDetail {
  id                      String                @id @default(uuid())
  integrationConnectionId String                @unique
  mailboxEmail            String
  grantedScopesJson       Json
  calendarIdsJson         Json?
  tokenExpiresAt          DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model TwilioConnectionDetail {
  id                      String                @id @default(uuid())
  integrationConnectionId String                @unique
  accountSid              String
  encryptedAuthToken      String?
  messagingServiceSid     String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model StripeCustomerRef {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
}

model PhoneNumber {
  id                  String    @id @default(uuid())
  tenantId            String
  twilioNumberSid     String?
  twilioSubaccountSid String? // null = on master account; populated once subaccount exists
  e164Number          String    @unique
  displayLabel        String?
  monthlyPriceCents   Int? // captured at purchase time so we can show it without re-querying Twilio
  notes               String? // tenant-facing free-text note for the number (e.g. "main reception")
  isInboundEnabled    Boolean   @default(false)
  isOutboundEnabled   Boolean   @default(false)
  isSmsEnabled        Boolean   @default(false)
  forwardingTarget    String?
  // Cancellation grace period — when set, number is marked for release at this time.
  // Background job (or check-on-fetch) releases it when reached.
  releaseScheduledAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// One row per tenant — created lazily on the tenant's FIRST number purchase.
// Stores the Twilio subaccount SID + encrypted subaccount auth token.
// Numbers, brands, billing in Twilio are scoped to this subaccount.
model TenantTwilioSubaccount {
  id                           String                 @id @default(uuid())
  tenantId                     String                 @unique
  twilioSubaccountSid          String                 @unique
  encryptedSubaccountAuthToken String
  status                       TwilioSubaccountStatus @default(ACTIVE)
  // Set when tenant cancels their subscription. After cancellationGraceUntil
  // expires we release all the subaccount's resources and close it.
  cancellationGraceUntil       DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  tenant                       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum TwilioSubaccountStatus {
  ACTIVE
  PENDING_CLOSURE // grace period running
  CLOSED // closed on Twilio's side
  SUSPENDED // platform-side suspension (abuse, etc.)
}

// A2P 10DLC application — captured per tenant for SMS compliance.
// Submission to Twilio Trust Hub APIs is gated on platform's ISV approval;
// until then this stores the data so we can submit in bulk once unblocked.
model TenantA2PApplication {
  id                       String               @id @default(uuid())
  /// Null for platform-scope (MyOrbisVoice's own A2P registration on the
  /// master Twilio account). Set for tenant-scope (each tenant's
  /// subaccount registration). At most one row per tenant + at most one
  /// platform-scope row.
  tenantId                 String?              @unique
  legalName                String // exact business legal name (matches EIN registration)
  ein                      String? // US EIN — optional for sole-prop
  businessType             String // SOLE_PROP / LLC / CORP / NON_PROFIT etc.
  vertical                 String // healthcare, retail, professional_services, etc.
  websiteUrl               String?
  addressLine1             String
  addressLine2             String?
  city                     String
  region                   String // state for US
  postalCode               String
  country                  String               @default("US")
  contactFirstName         String
  contactLastName          String
  contactEmail             String
  contactPhone             String
  useCase                  String // marketing / mixed / customer_care / 2fa / utility
  sampleMessagesJson       Json // array of 5 sample SMS bodies
  twilioCustomerProfileSid String? // populated after submit to Trust Hub
  twilioBrandSid           String? // populated after Brand creation
  twilioCampaignSid        String? // populated after Campaign creation
  status                   A2PApplicationStatus @default(DRAFT)
  rejectionReason          String?
  submittedAt              DateTime?
  approvedAt               DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  tenant                   Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatorNotes            A2POperatorNote[]
}

enum A2PApplicationStatus {
  DRAFT // tenant filling form
  SUBMITTED // posted to Twilio Trust Hub, vetting in progress
  APPROVED // Brand + Campaign approved, numbers can send SMS at full throughput
  REJECTED // Twilio rejected the brand/campaign
}

/// Append-only friction log for A2P submissions. Operators add a note every
/// time they have to email a tenant for clarification, find a missing field,
/// hit a Twilio rejection, etc. After ~20 submissions this becomes the
/// data-driven design input for the future self-service A2P wizard.
model A2POperatorNote {
  id            String                  @id @default(uuid())
  applicationId String
  byUserId      String // admin user who wrote the note
  category      A2POperatorNoteCategory
  note          String // free-form description, max ~2000 chars enforced at API layer
  createdAt     DateTime                @default(now())
  application   TenantA2PApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  byUser        User                    @relation(fields: [byUserId], references: [id], onDelete: Restrict)

  @@index([applicationId, createdAt])
  @@index([category])
}

enum A2POperatorNoteCategory {
  CLARIFICATION_NEEDED // had to email tenant for more info
  DATA_GAP // tenant left a required field blank or stub
  FORMAT_ERROR // tenant entered something in wrong format (EIN, phone, URL)
  USE_CASE_MISMATCH // sample messages don't match declared use case
  COMPLIANCE_CONCERN // pre-emptive flag — Twilio likely to reject if submitted as-is
  OTHER
}

// Web Push subscription — one row per browser/device. Created when the user
// grants permission. Used to fire desktop notifications on call events.
model PushSubscription {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  endpoint   String   @unique
  p256dh     String // browser public key for E2E encryption
  auth       String // browser auth secret
  userAgent  String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Contact {
  id                  String                @id @default(uuid())
  tenantId            String
  firstName           String?
  lastName            String?
  fullName            String?
  email               String?
  phoneE164           String?
  addressLine1        String?
  city                String?
  region              String?
  postalCode          String?
  country             String?
  source              String
  tagsJson            Json?
  metadataJson        Json?
  emailStatus         String?
  emailVerifiedAt     DateTime?
  phoneStatus         String?
  phoneVerifiedAt     DateTime?
  agentConfirmedAt    DateTime?
  optedOutSms         Boolean               @default(false)
  optedOutSmsAt       DateTime?
  optedOutVoice       Boolean               @default(false)
  optedOutVoiceAt     DateTime?
  optedOutEmail       Boolean               @default(false)
  optedOutEmailAt     DateTime?
  optedOutWhatsapp    Boolean               @default(false)
  optedOutWhatsappAt  DateTime?
