  @@index([tenantId, phoneE164])
}

model Conversation {
  id                    String                @id @default(uuid())
  tenantId              String
  contactId             String?
  channelType           ChannelType
  direction             ConversationDirection
  status                ConversationStatus
  startedAt             DateTime
  endedAt               DateTime?
  summaryText           String?
  transcriptRef         String?
  transcriptJson        Json?
  outcomeCode           String?
  outcomeJson           Json?
  externalCallId        String?
  recordingRef          String?
  recordingBunnyPath    String?
  recordingDurationSecs Int?
  recordingStatus       String?
  recordingSizeBytes    BigInt?
  /// Free-form metadata about the call: per-turn latency, diagnostic flags, etc.
  /// Read by the latency-report CLI; written by the voice gateway on call finalize.
  metadataJson          Json?

  // ── Partner context (Phase E.2) ───────────────────────────────────────────
  // Set when this conversation originated on a partner's landing page widget.
  // Drives where book_appointment writes: partnerId set → partner's Google
  // Calendar; partnerId null → tenant's Google Calendar (the existing flow).
  partnerId             String?

  // ── Demo Gallery (Phase D.1) ──────────────────────────────────────────────
  // Conversations curated by admin as public demos at /demos/<id>.
  // featuredSummary / featuredTranscript override the raw fields when set,
  // letting admin redact PII before publishing without losing the originals.
  isFeaturedDemo        Boolean               @default(false)
  featuredTitle         String?               // e.g. "Bright Smile Dental — after-hours booking"
  featuredCategory      String?               // dental | legal | hvac | beauty | fitness | real-estate | coaching | medical
  featuredSortOrder     Int                   @default(100)
  featuredAt            DateTime?
  featuredById          String?               // FK to User (admin who curated it)
  featuredSummary       String?               // redacted display summary (falls back to summaryText)
  featuredTranscript    Json?                 // redacted transcript (falls back to transcriptJson)
  featuredViewCount     Int                   @default(0)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact               Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  featuredBy            User?                 @relation("DemoFeaturedBy", fields: [featuredById], references: [id], onDelete: SetNull)
  partner               AffiliateAccount?     @relation("PartnerConversations", fields: [partnerId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  messageLogs           MessageLog[]
  callLogs              CallLog[]
  outboundCallAttempts  OutboundCallAttempt[]

  @@index([tenantId, startedAt])
  @@index([tenantId, channelType])
  @@index([externalCallId])
  @@index([isFeaturedDemo, featuredCategory, featuredSortOrder])
  @@index([partnerId])
}

model StaffMember {
