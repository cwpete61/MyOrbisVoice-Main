  secretType      String
  label           String
  provider        String
  externalRef     String?
  lastValidatedAt DateTime?
  rotationStatus  RotationStatus  @default(UNKNOWN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([ownerType, ownerId, secretType, label])
}

model ImpersonationSession {
  id             String     @id @default(uuid())
  adminUserId    String
  tenantId       String
  assumedRoleKey String
  reasonCode     String?
  notes          String?
  startedAt      DateTime   @default(now())
  endedAt        DateTime?
  adminUser      User       @relation("ImpersonationStartedBy", fields: [adminUserId], references: [id], onDelete: Cascade)
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]

  @@index([tenantId, startedAt])
  @@index([adminUserId, startedAt])
}

// Short-lived token issued to the browser widget before a voice session starts.
// The voice gateway verifies this token, then upgrades to a full session.
model WidgetSession {
  id                      String              @id @default(uuid())
  tenantId                String
  contactId               String?
  token                   String              @unique
  status                  WidgetSessionStatus @default(PENDING)
  channelConfigId         String?
  promptSnapshotJson      Json?
  businessDNASnapshotJson Json?
  metadataJson            Json?
  conversationId          String?
  remoteIp                String?
  userAgent               String?
  expiresAt               DateTime
  startedAt               DateTime?
  endedAt                 DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  tenant                  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// One-time password-reset tokens. Created when a user requests a reset via
/// /forgot-password, consumed via /reset-password. Token sent in the email
/// is the raw bytes; what's stored here is sha256(raw) — same pattern as
/// RefreshToken so a DB leak doesn't compromise pending resets.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime  // 15 minutes from createdAt — short TTL is the security gate
  usedAt    DateTime? // single-use; set when the token is redeemed
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OutboundCampaign {
  id              String                @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  status          CampaignStatus        @default(DRAFT)
  audienceJson    Json?
  scheduleJson    Json?
  promptVersionId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attempts        OutboundCallAttempt[]
}

model OutboundCallAttempt {
  id             String              @id @default(uuid())
  campaignId     String
  tenantId       String
  contactId      String
  providerCallId String?             @unique
  status         String
  attemptNumber  Int                 @default(1)
  startedAt      DateTime?
  endedAt        DateTime?
  outcomeCode    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  conversationId String?
  // Optional back-reference to a tag-driven Campaign enrollment when the
  // outbound call was triggered by the campaign scheduler. The webhook
  // outcome handler propagates the call result back to this enrollment.
  enrollmentId   String?
  campaign       OutboundCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation   Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  enrollment     CampaignEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([enrollmentId])
}

model SystemConfig {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model StorageTierConfig {
  tier            String   @id // LTD | BASIC | ESSENTIALS | PREMIUM | ENTERPRISE
  quotaBytes      BigInt
  retentionDays   Int?
  gracePeriodDays Int      @default(30)
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

model TwilioEventLog {
  id           String   @id @default(uuid())
  tenantId     String
  callSid      String?
  direction    String // INBOUND | OUTBOUND
  eventType    String // amd | status | error | inbound_received | inbound_error
  callStatus   String? // completed | busy | no-answer | failed | canceled
  answeredBy   String? // AMD result: human | machine_start | machine_end_beep | etc
  fromNumber   String?
  toNumber     String?
  durationSecs Int?
  outcomeCode  String?
  errorMessage String?
  metaJson     Json?
  occurredAt   DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, callSid])
}

// Platform-level pre-built campaign templates per vertical
model CampaignTemplate {
  id                        String           @id @default(uuid())
  vertical                  IndustryVertical
  campaignType              CampaignType
  name                      String
  description               String
  defaultPrompt             String
  defaultTriggerTag         String
  defaultDelayHours         Int              @default(1)
  defaultMaxRetries         Int              @default(2)
  defaultRetryIntervalHours Int              @default(24)
  suggestedTagsJson         Json?
  isActive                  Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  campaigns                 Campaign[]

  @@unique([vertical, campaignType])
  @@index([vertical])
}

// Tenant's activated campaign instance
model Campaign {
  id                 String               @id @default(uuid())
  tenantId           String
  templateId         String?
  campaignType       CampaignType
  name               String
  description        String?
  prompt             String
  triggerTag         String
  delayHours         Int                  @default(1)
  maxRetries         Int                  @default(2)
  retryIntervalHours Int                  @default(24)
  isActive           Boolean              @default(false)
  exitOnReply        Boolean              @default(true)
  exitOnOptOut       Boolean              @default(true)
  enableVoice        Boolean              @default(true)
  enableSms          Boolean              @default(false)
  enableEmail        Boolean              @default(false)
  enableWhatsapp     Boolean              @default(false)
  smsBody            String?
  whatsappBody       String?
  emailSubject       String?
  emailBody          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template           CampaignTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  enrollments        CampaignEnrollment[]

  @@index([tenantId, isActive])
  @@index([tenantId, triggerTag])
}

// Tracks each contact's journey through a campaign on a specific channel.
// One row per (campaign, contact, channel) — a single trigger fan-outs into
// up to 4 enrollments (one per enabled channel on the campaign).
model CampaignEnrollment {
  id              String                @id @default(uuid())
  tenantId        String
  campaignId      String
  contactId       String
  channel         EnrollmentChannel     @default(VOICE)
  status          EnrollmentStatus      @default(PENDING)
  triggerTag      String
  triggeredAt     DateTime              @default(now())
  scheduledCallAt DateTime?
  lastAttemptAt   DateTime?
  attemptCount    Int                   @default(0)
  completedAt     DateTime?
  exitReason      String?
  metaJson        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign        Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact         Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  voiceAttempts   OutboundCallAttempt[]

  @@unique([campaignId, contactId, channel])
  @@index([tenantId, status])
  @@index([tenantId, scheduledCallAt])
  @@index([status, scheduledCallAt])
}

enum EnrollmentChannel {
  VOICE
  SMS
  EMAIL
  WHATSAPP
}

// Immutable opt-out event log — one row per opt-out or opt-in event
model OptOutLog {
  id        String   @id @default(uuid())
  tenantId  String
  contactId String
  channel   String // SMS | VOICE | EMAIL
  source    String // REPLY_STOP | REPLY_START | VOICE_REQUEST | MANUAL | WEBHOOK
  optedOut  Boolean // true = opted out, false = opted back in
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, channel, createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  tenantId  String
  type      String // storage_warning | storage_critical | twilio_error | google_expiring | campaign_complete | admin_broadcast | opt_out_received | contact_created
  priority  String    @default("info") // critical | warning | info
  title     String
  body      String
  linkPath  String? // optional deep link e.g. /billing or /contacts/123
  readAt    DateTime?
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, readAt, createdAt])
  @@index([tenantId, type])
}
