  @@index([vertical])
  @@index([subcategory])
}

enum EventSubcategory {
  HOLIDAY
  SALES_EVENT
  SPECIAL_EVENT
}

// Tenant's activated campaign instance
model Campaign {
  id                 String               @id @default(uuid())
  tenantId           String
  templateId         String?
  campaignType       CampaignType
  name               String
  description        String?
  prompt             String
  triggerTag         String
  delayHours         Int                  @default(1)
  maxRetries         Int                  @default(2)
  retryIntervalHours Int                  @default(24)
  isActive           Boolean              @default(false)
  exitOnReply        Boolean              @default(true)
  exitOnOptOut       Boolean              @default(true)
  enableVoice        Boolean              @default(true)
  enableSms          Boolean              @default(false)
  enableEmail        Boolean              @default(false)
  enableWhatsapp     Boolean              @default(false)
  smsBody            String?
  whatsappBody       String?
  emailSubject       String?
  emailBody          String?
  // Per-campaign aggression override (null = use BusinessProfile.aggressionTier).
  // Lets a tenant pick a different intensity for a launch event vs steady-state
  // campaigns. See docs/marketing-style-guide.md.
  aggressionTier     String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template           CampaignTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  enrollments        CampaignEnrollment[]

  @@index([tenantId, isActive])
  @@index([tenantId, triggerTag])
}

// Tracks each contact's journey through a campaign on a specific channel.
// One row per (campaign, contact, channel) — a single trigger fan-outs into
// up to 4 enrollments (one per enabled channel on the campaign).
model CampaignEnrollment {
  id              String                @id @default(uuid())
  tenantId        String
  campaignId      String
  contactId       String
  channel         EnrollmentChannel     @default(VOICE)
  status          EnrollmentStatus      @default(PENDING)
  triggerTag      String
  triggeredAt     DateTime              @default(now())
  scheduledCallAt DateTime?
  lastAttemptAt   DateTime?
  attemptCount    Int                   @default(0)
  completedAt     DateTime?
  exitReason      String?
  metaJson        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign        Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact         Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  voiceAttempts   OutboundCallAttempt[]

  @@unique([campaignId, contactId, channel])
  @@index([tenantId, status])
  @@index([tenantId, scheduledCallAt])
  @@index([status, scheduledCallAt])
}

enum EnrollmentChannel {
  VOICE
  SMS
  EMAIL
  WHATSAPP
}

// Immutable opt-out event log — one row per opt-out or opt-in event
model OptOutLog {
  id        String   @id @default(uuid())
  tenantId  String
  contactId String
  channel   String // SMS | VOICE | EMAIL
  source    String // REPLY_STOP | REPLY_START | VOICE_REQUEST | MANUAL | WEBHOOK
  optedOut  Boolean // true = opted out, false = opted back in
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, channel, createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  tenantId  String
  type      String // storage_warning | storage_critical | twilio_error | google_expiring | campaign_complete | admin_broadcast | opt_out_received | contact_created
  priority  String    @default("info") // critical | warning | info
  title     String
  body      String
  linkPath  String? // optional deep link e.g. /billing or /contacts/123
  readAt    DateTime?
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, readAt, createdAt])
  @@index([tenantId, type])
}

// ─── Phase F.4 — Email reputation foundation ───────────────────────────────
// Suppression list = the source of truth for "do not email." Every send path
// (transactional + bulk) consults this before handing off to the provider.
// Reasons capture WHY an address was suppressed so we can surface it to
// partners (manual unsubscribe is recoverable; hard bounce is not).
//
// Scope is intentionally three-way:
//   1. Global (tenantId NULL, partnerId NULL) — hard bounces and complaints
//      get suppressed platform-wide. A single proven-dead address shouldn't
//      be retried by anyone, ever.
//   2. Tenant-scoped (tenantId set, partnerId NULL) — tenant manually adds
//      "do not contact" addresses or marketing-only opt-outs.
//   3. Partner-scoped (partnerId set, tenantId mirrored from hosting tenant)
//      — partner's own unsubscribes don't bleed into other partners' lists,
//      because two partners' value props may legitimately differ.

enum EmailSuppressionReason {
  HARD_BOUNCE // ESP webhook reported hard bounce — never retry
  COMPLAINT // recipient hit "this is spam" — never retry
  UNSUBSCRIBE // recipient clicked the unsubscribe footer link
  MANUAL // partner / tenant added the address by hand
  SOFT_BOUNCE_REPEATED // 5+ soft bounces in 30d — treat as hard
}

model EmailSuppression {
  id        String                 @id @default(uuid())
  // Scope: at most one of (tenantId, partnerId) should be set. Both null =
  // global suppression. Application enforces the invariant; the column
  // shape allows simple WHERE OR queries from the send path.
  tenantId  String?
  partnerId String?
  email     String                 @db.VarChar(320) // RFC 5321 max
  reason    EmailSuppressionReason
  note      String? // freeform — ESP error message, partner annotation, etc.
  createdAt DateTime               @default(now())

  tenant  Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner AffiliateAccount? @relation("PartnerEmailSuppressions", fields: [partnerId], references: [id], onDelete: Cascade)

  // Lookup is always "is this email suppressed for this scope?" → index
  // covers the three-way OR cleanly when query orders email first.
  @@index([email])
  @@index([tenantId, email])
  @@index([partnerId, email])
  @@index([tenantId, createdAt])
  @@index([partnerId, createdAt])
}

// Bulk email campaign — partner picks recipients, writes a template, schedules.
// A worker drains the recipient list at the partner's drip interval, respecting
// the daily cap and send window. Status transitions:
//   DRAFT → SCHEDULED → RUNNING → (PAUSED | COMPLETED | FAILED)
// PAUSED happens automatically when hard-bounce rate exceeds the auto-halt
// threshold mid-run, or manually by the partner.

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELED
}

model EmailCampaign {
  id              String              @id @default(uuid())
  tenantId        String // hosting tenant (always set; mirrors AffiliateAccount.partnerId tenant)
  partnerId       String? // null = tenant-side campaign (future); set = partner campaign
  name            String              @db.VarChar(120)
  subject         String              @db.VarChar(200)
  bodyText        String              @db.Text // plain-text template (no rendering yet — partner pastes content)
  bodyHtml        String?             @db.Text // optional pre-rendered HTML
  fromName        String? // overrides partner displayName if set
  status          EmailCampaignStatus @default(DRAFT)
  scheduledAt     DateTime? // null = send-when-RUNNING (manual start)
  startedAt       DateTime?
  completedAt     DateTime?
  pausedReason    String? // populated when status flipped to PAUSED
  // Counters maintained by the worker as it drains the queue. Reading these
  // is much cheaper than aggregating EmailCampaignRecipient on every poll.
  totalRecipients Int                 @default(0)
  sentCount       Int                 @default(0)
  bouncedCount    Int                 @default(0)
  complainedCount Int                 @default(0)
  skippedCount    Int                 @default(0) // suppression hits + opt-outs
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner    AffiliateAccount?        @relation("PartnerEmailCampaigns", fields: [partnerId], references: [id], onDelete: Cascade)
  recipients EmailCampaignRecipient[]

  @@index([partnerId, status, createdAt])
  @@index([tenantId, status])
  @@index([status, scheduledAt]) // worker scan path
}

enum EmailCampaignRecipientStatus {
  PENDING // waiting in the queue
  SENT // handed to ESP; awaiting bounce window
  DELIVERED // ESP confirmed delivery
  BOUNCED // hard bounce — also added to suppression
  COMPLAINED
  SKIPPED // suppression hit before send
  FAILED // ESP rejected synchronously (auth error, malformed, etc.)
}

model EmailCampaignRecipient {
  id           String                       @id @default(uuid())
  campaignId   String
  // Recipient source is polymorphic. Today: contactId points at a partner's
  // CRM Contact. Future (scraping system): leadId points at a Lead row from
  // the scraped industry pool. Exactly one should be non-null.
  contactId    String?
  // leadId      String?  // wired in Phase F.5 when Lead model lands
  email        String                       @db.VarChar(320) // snapshotted at queue time
  name         String?                      @db.VarChar(200) // snapshotted for template merge
  status       EmailCampaignRecipientStatus @default(PENDING)
  sentAt       DateTime?
  messageLogId String? // ← MessageLog.id once handed to ESP
  errorReason  String?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([campaignId, email]) // can't queue the same address twice in one campaign
  @@index([campaignId, status])
  @@index([status, sentAt]) // worker scan
}

// ── Marketing Kit (admin-managed partner-facing video library) ──────────────
// Replaces the hardcoded VIDEOS array in the partner Marketing Kit page so
// platform admins can upload, edit, reorder, and delete videos without a
// code deploy. The asset proxy (apps/api/src/routes/marketing-assets.ts)
// reads its whitelist from this table at request time.

model MarketingKitVideo {
  id            String  @id @default(uuid())
  // One of: 'pitch-product' | 'recruit-partners' | 'how-to-sell' | 'social-cuts'
  //       | 'social-posts' | 'reels-shorts-tiktok' | 'audio' | 'youtube-longform'.
  // Tabs are fixed in the partner UI; admins only manage the videos within them.
  intent        String
  titleEn       String
  titleEs       String
  descriptionEn String
  descriptionEs String
  // Filename under marketing-kit/ on Bunny storage. The proxy looks up this
  // column to decide if a public asset URL is serveable. Null = placeholder
  // ("Coming Soon" card with no playable file yet).
  filename      String? @unique
  durationSec   Int     @default(0)
  // 'horizontal' (16:9) or 'vertical' (9:16). The partner card uses this to
  // pick the correct aspect-ratio thumbnail container.
  aspectRatio   String  @default("horizontal")
  comingSoon    Boolean @default(false)
  // Draft toggle — when false, hidden from the partner-facing list, still
  // visible (and editable) in the admin table.
  visible       Boolean @default(true)
  // Manual ordering for the "All" tab and within each intent group.
  sortOrder     Int     @default(0)

  // ── Social Content Engine extensions (Phase B) ─────────────────────────────
  // 'video' | 'image' | 'audio' | 'carousel'. Legacy rows default to 'video';
  // partner page picks the right player (modal for video, inline for audio,
  // lightbox for image/carousel).
  mediaType          String   @default("video")
  // Mime type the marketing-asset proxy serves with. Null = derive from
  // extension at request time.
  mimeType           String?
  // Carousel slides 2..N (filename basenames under marketing-kit/). Empty
  // for non-carousel rows. First slide = `filename` for back-compat.
  secondaryFilenames String[] @default([])
  // Per-platform caption variants from the AI copy generator. Shape:
  // { x?: string, ig?: string, linkedin?: string, tiktok?: string }
  captionsJson       Json?
  // YouTube long-form sub-track only: 'partner' | 'corporate'. Null for
  // every other intent.
  track              String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@index([intent, sortOrder])
  @@index([visible, sortOrder])
  @@index([mediaType])
  @@index([updatedAt])
}

// Singleton settings for the partner Marketing Kit grid. One row, id = 'singleton'.
model MarketingKitSettings {
  id             String   @id @default("singleton")
  columnsDesktop Int      @default(3)
  columnsTablet  Int      @default(2)
  columnsMobile  Int      @default(1)
  // 'manual' (uses sortOrder) | 'newest' | 'duration'
  defaultSort    String   @default("manual")
  // 'all' | one of the intent slugs above
  defaultTab     String   @default("all")
  // Intent slugs hidden from the partner Marketing Kit. Each entry must
  // be one of: 'pitch-product' | 'recruit-partners' | 'how-to-sell' | 'social-cuts'.
  // Admin still sees every tab in the admin panel; the hide is partner-side only.
  hiddenTabs     String[] @default([])
  updatedAt      DateTime @updatedAt
}

// ============================================================================
// WEBINAR MARKETING — partner-scoped lead discovery + invite list system
//
// Compliance-first design. Free-mail addresses NEVER auto-promote to
// WebinarInviteContact; they require manual review with consentStatus +
// lawfulBasisNotes. SourceUrl is always stored to satisfy GDPR Art. 14
// disclosure-of-source requirement.
//
// Pipeline:
//   LeadList → SearchQuery → DiscoveredUrl → ExtractedEmail
//   → EmailVerification → (gates) → WebinarInviteContact
//                                  ↓ rejected
//                              ManualReviewQueue (free-mail / risky / unknown)
//                                  ↓ approved
//                              WebinarInviteContact
// ============================================================================

enum WebinarListStatus {
  DRAFT
  DISCOVERING
  EXTRACTING
  VERIFYING
  READY
  ARCHIVED
}

enum WebinarSearchStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum WebinarUrlStatus {
  PENDING
  CRAWLED
  SKIPPED_ROBOTS
  SKIPPED_RATE_LIMIT
  FAILED
}

enum WebinarEmailType {
  BUSINESS_DOMAIN
  ROLE_BASED_BUSINESS
  PERSONAL_FREE_MAIL
  NO_REPLY_OR_SUPPRESSED
  INVALID_FORMAT
  DISPOSABLE_DOMAIN
  MANUAL_REVIEW_REQUIRED
}

enum WebinarClassificationStatus {
  PENDING
  CLASSIFIED
  QUARANTINED
  REJECTED
  APPROVED
}

enum WebinarVerificationStatus {
  DELIVERABLE
  UNDELIVERABLE
  RISKY
  UNKNOWN
  PENDING
}

enum WebinarConsentStatus {
  OPTED_IN
  EXISTING_CUSTOMER
  MANUAL_LAWFUL_BASIS_REVIEWED
  NOT_APPROVED
}

enum WebinarVerificationMode {
  SYNTAX_DNS_ONLY
  EXTERNAL_PROVIDER
}

// One named lead list per discovery campaign. Partner-scoped (every row tied
// to an AffiliateAccount). Each list defines its own niche/location/search
// config and is the parent of all downstream rows.
model WebinarLeadList {
  id                        String                  @id @default(uuid())
  partnerId                 String
  name                      String
  niche                     String
  location                  String
  // Optional filter: when set, only emails on this domain (or its subdomains)
  // are extracted. Example: "example.com". Null = no domain filter.
  optionalEmailDomainFilter String?
  // Array of provider slugs the operator selected for this list. Values:
  // "duckduckgo" | "bing_web_search" | "google_scrape" | "serpapi" |
  // "google_custom_search".
  searchEngines             String[]                @default([])
  maxResultsPerQuery        Int                     @default(100)
  maxPagesPerDomain         Int                     @default(5)
  verificationMode          WebinarVerificationMode @default(EXTERNAL_PROVIDER)
  // Array of WebinarEmailType-ish strings indicating what's eligible for
  // auto-promotion. Defaults exclude personal_free_mail (quarantine only).
  // Values: "business_domain_only" | "role_based_business" | "manual_review_free_mail".
  allowedEmailTypes         String[]                @default(["business_domain_only", "role_based_business"])
  status                    WebinarListStatus       @default(DRAFT)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  // Soft-delete anchor. NULL = active.
  deletedAt                 DateTime?

  partner         AffiliateAccount        @relation("PartnerWebinarLists", fields: [partnerId], references: [id], onDelete: Cascade)
  searchQueries   WebinarSearchQuery[]
  discoveredUrls  WebinarDiscoveredUrl[]
  extractedEmails WebinarExtractedEmail[]
  inviteContacts  WebinarInviteContact[]

  @@index([partnerId, status])
  @@index([partnerId, createdAt])
}

// One row per (provider × generated query string). Records what was sent to
// each search engine. Used to dedup queries and audit per-provider usage.
model WebinarSearchQuery {
  id           String              @id @default(uuid())
  leadListId   String
  queryText    String
  provider     String // "duckduckgo" | "bing_web_search" | ...
  status       WebinarSearchStatus @default(PENDING)
  resultCount  Int                 @default(0)
  errorMessage String?
  createdAt    DateTime            @default(now())
  completedAt  DateTime?

  leadList       WebinarLeadList        @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  discoveredUrls WebinarDiscoveredUrl[]

  @@unique([leadListId, queryText, provider])
  @@index([leadListId, status])
}

// Each URL returned by a search provider. Same URL may appear multiple times
// across queries; we keep them all (partition by searchQueryId) and dedup at
// the email-extraction layer instead.
model WebinarDiscoveredUrl {
  id            String           @id @default(uuid())
  leadListId    String
  searchQueryId String
  url           String
  domain        String
  title         String?
  snippet       String?
  provider      String
  status        WebinarUrlStatus @default(PENDING)
  // Robots.txt result snapshotted at crawl time. "allowed" | "disallowed" |
  // "no_robots_file" | "fetch_failed". Null until crawler touches it.
  robotsCheck   String?
  errorMessage  String?
  discoveredAt  DateTime         @default(now())
  crawledAt     DateTime?

  leadList        WebinarLeadList         @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  searchQuery     WebinarSearchQuery      @relation(fields: [searchQueryId], references: [id], onDelete: Cascade)
  extractedEmails WebinarExtractedEmail[]

  @@index([leadListId, status])
  @@index([domain])
}

// One row per (sourceUrl × email) pair found during crawl. Pre-classification
// raw findings. Same email may appear from multiple URLs across lists; we
// dedup at the WebinarInviteContact promotion stage.
model WebinarExtractedEmail {
  id                   String                      @id @default(uuid())
  leadListId           String
  discoveredUrlId      String
  email                String
  // Lowercased + trimmed. Used for dedup + suppression lookup.
  normalizedEmail      String
  domain               String
  sourceUrl            String
  sourcePageTitle      String?
  // ~200-char text window around the email in HTML, for operator review.
  rawContextSnippet    String?
  emailType            WebinarEmailType?
  classificationStatus WebinarClassificationStatus @default(PENDING)
  // When operator quarantines/rejects/approves, optional note.
  reviewerNotes        String?
  createdAt            DateTime                    @default(now())

  leadList      WebinarLeadList            @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  discoveredUrl WebinarDiscoveredUrl       @relation(fields: [discoveredUrlId], references: [id], onDelete: Cascade)
  verifications WebinarEmailVerification[]

  @@index([leadListId, classificationStatus])
  @@index([normalizedEmail])
  @@index([domain])
}

// Verification result from internal or external provider. Multiple rows
// per ExtractedEmail possible (e.g. re-verification weeks later).
model WebinarEmailVerification {
  id                 String   @id @default(uuid())
  extractedEmailId   String
  normalizedEmail    String
  syntaxValid        Boolean
  mxValid            Boolean
  disposable         Boolean  @default(false)
  // "deliverable" | "undeliverable" | "risky" | "unknown" | "skipped".
  // Mirrors WebinarVerificationStatus but kept as string for forward-compat
  // with new provider statuses.
  providerStatus     String
  providerConfidence Float?
  providerReason     String?
  provider           String // "reoon" | "zerobounce" | "internal_dns"
  verifiedAt         DateTime @default(now())

  extractedEmail WebinarExtractedEmail @relation(fields: [extractedEmailId], references: [id], onDelete: Cascade)

  @@index([extractedEmailId])
  @@index([normalizedEmail])
}

// Final, gated, ready-to-invite contact. Promotion gated by:
//   - syntaxValid + mxValid + disposable=false
//   - providerStatus = "deliverable"
//   - not in WebinarSuppression
//   - sourceUrl present
//   - consentStatus != NOT_APPROVED
//   - if consentStatus = MANUAL_LAWFUL_BASIS_REVIEWED then lawfulBasisNotes required
//   - dedup by normalizedEmail within (partnerId, leadListId) AND across all
//     partner lists (one promotion per email per partner)
model WebinarInviteContact {
  id                 String                    @id @default(uuid())
  leadListId         String
  partnerId          String
  email              String
  normalizedEmail    String
  businessName       String?
  niche              String
  location           String
  sourceUrl          String
  consentStatus      WebinarConsentStatus
  lawfulBasisNotes   String?
  verificationStatus WebinarVerificationStatus
  addedAt            DateTime                  @default(now())
  lastInvitedAt      DateTime?
  unsubscribedAt     DateTime?

  leadList WebinarLeadList  @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  partner  AffiliateAccount @relation("PartnerWebinarContacts", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, normalizedEmail])
  @@index([leadListId])
  @@index([unsubscribedAt])
}

// Suppression list — global per partner. Any email added here will never
// auto-promote, regardless of source. Unsubscribe webhook writes here.
model WebinarSuppression {
  id              String   @id @default(uuid())
  partnerId       String
  email           String
  normalizedEmail String
  // "unsubscribed" | "bounce" | "complaint" | "manual" | "role_suppressed" |
  // "imported".
  reason          String
  source          String?
  createdAt       DateTime @default(now())

  partner AffiliateAccount @relation("PartnerWebinarSuppressions", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, normalizedEmail])
  @@index([partnerId])
}

// Append-only audit log for the Webinar Marketing module. Mirrors the
// platform AuditLog pattern but partner-scoped + module-scoped to avoid
// noise in the platform audit table.
model WebinarAuditLog {
  id          String   @id @default(uuid())
  partnerId   String
  // "list_created" | "discovery_started" | "url_crawled" | "email_extracted" |
  // "email_classified" | "email_verified" | "promoted_to_invite" |
  // "suppression_hit" | "manual_review_approved" | "exported_csv" | ...
  action      String
  entityType  String? // "WebinarLeadList" | "WebinarExtractedEmail" | ...
  entityId    String?
  detailsJson Json?
  createdAt   DateTime @default(now())

  @@index([partnerId, createdAt])
  @@index([action])
}

// ============================================================================
// PARTNER DAILY ACTIVITY — daily playbook checkbox tracker
//
// One row per (partner × activityKey × dayKey). dayKey = YYYY-MM-DD in
// partner-local time. Tick → row insert; untick → row delete. Yesterday's
// rows stay for history + rollup metrics. Midnight = new dayKey = fresh
// checkboxes for the new day.
//
// Activity catalog (section / key / label / importance / target / follow-ups)
// lives in code at apps/api/src/services/partner-daily-activity/catalog.ts —
// NOT in the DB. The catalog evolves with the playbook + needs i18n; tying
// it to a table forces a migration every time we add a coaching activity.
// ============================================================================
model PartnerDailyActivityProgress {
  id          String   @id @default(uuid())
  partnerId   String
  // Slug from the catalog. Format: `<section>.<sub>.<verb>`
  // (e.g. `morning.cold_calls.10`).
  activityKey String
  // YYYY-MM-DD in partner-local time. Computed server-side.
  dayKey      String
  completedAt DateTime @default(now())
  // Optional reviewer-supplied note; ≤500 chars.
  notes       String?

  partner AffiliateAccount @relation("PartnerDailyActivities", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, activityKey, dayKey])
  @@index([partnerId, dayKey])
  @@index([dayKey])
}

// ── My Groups — partner FB-group tracker + compliant cadence coach ──────────
// Tracks groups a partner has MANUALLY joined + each post they MANUALLY made,
// for attribution (which group converts) and anti-spam pacing (throttle +
// cooldown + content rotation). The platform never auto-joins, auto-posts, or
// auto-engages — it paces the human. See docs/campaigns/campaign-automation-roadmap.md.
model PartnerGroup {
  id          String    @id @default(uuid())
  partnerId   String
  name        String
  url         String?
  niche       String?
  memberCount Int?
  promoRule   String?   // "open" | "fridays" | "none" | freeform note
  status      String    @default("active") // active | left | banned
  joinedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([partnerId, status])
}

model PartnerGroupPost {
  id         String   @id @default(uuid())
  partnerId  String
  groupId    String
  track      String   // beta | phantom | competitor | math | afterhours | quiz
  keyword    String?
  optinCount Int      @default(0)
  postedAt   DateTime @default(now())

  @@index([partnerId, groupId])
  @@index([partnerId, postedAt])
}

// MyOrbisAgents — real-estate AGENT PROSPECT (operator outreach tooling, moved from
// MyOrbisBiz into the Voice app per plan §25 Option A). Paste a Zillow blob → AI
// extract → deterministic fit rubric → ranked target with a light pipeline.
// ownerId is the partner-ready seam (§22): null = house/us.
model AgentProspect {
  id              String   @id @default(uuid())
  ownerId         String?
  name            String
  brokerage       String?
  market          String?
  email           String?
  phone           String?
  salesLast12     Int?
  totalSales      Int?
  isTeam          Boolean  @default(false)
  teamSize        String?
  avgPriceUsd     Int?
  priceRange      String?
  yearsExp        Int?
  reviews         Int?
  premierAgent    Boolean  @default(false)
  language        String?
  score           Int      @default(0)
  tier            String   @default("C")
  recommendedTier String?
  pitchAngle      String?
  redFlags        String?
  rawText         String?
  status          String   @default("TARGET")
  demoSlug        String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([score])
}

// MyOrbisAgents — the agent's property book. Each Listing is a working unit Orby
// answers from (§17c). Descriptions are AI-formatted Fair-Housing-safe.
// ownerId is the partner-ready seam (§22): null = house/us.
enum ListingStatus {
  ACTIVE
  COMING_SOON
  PENDING
  SOLD
  POCKET
  OFF_MARKET
}

model Listing {
  id          String        @id @default(uuid())
  tenantId    String
  ownerId     String?
  status      ListingStatus @default(ACTIVE)
  isActive    Boolean       @default(true)
  address     String
  headline    String?
  priceUsd    Int?
  beds        Float?
  baths       Float?
  sqft        Int?
  propertyType String?
  description String?
  highlights  String[]
  rawText     String?
  // Enrichment (§backlog 24) — geocoded once, then a cached neighborhood/property
  // data blob (AVM, comps, flood, POIs…) refreshed on a TTL. Never on the hot path.
  lat            Float?
  lng            Float?
  enrichmentJson Json?
  enrichedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumbers  PhoneNumber[]  @relation("ListingTrackingNumber")
  conversations Conversation[] @relation("ListingConversation")

  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@index([ownerId])
}
