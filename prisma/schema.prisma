  contactId      String
  providerCallId String?             @unique
  status         String
  attemptNumber  Int                 @default(1)
  startedAt      DateTime?
  endedAt        DateTime?
  outcomeCode    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  conversationId String?
  // Optional back-reference to a tag-driven Campaign enrollment when the
  // outbound call was triggered by the campaign scheduler. The webhook
  // outcome handler propagates the call result back to this enrollment.
  enrollmentId   String?
  campaign       OutboundCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
