  totalEarnedCents       Int                      @default(0)
  totalPaidCents         Int                      @default(0)
  approvedAt             DateTime?
  notes                  String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks                 AffiliateClick[]
  conversions            AffiliateConversion[]
  commissions            AffiliateCommission[]
  payoutRequests         AffiliatePayoutRequest[]
  customLinks            AffiliateCustomLink[]
}

model AffiliateCustomLink {
  id                 String           @id @default(uuid())
  affiliateAccountId String
  slug               String           @unique
  label              String
  notes              String?
  archivedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  affiliateAccount   AffiliateAccount @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)
  clicks             AffiliateClick[]

  @@index([affiliateAccountId, archivedAt])
}

model AffiliatePayoutRequest {
  id                 String           @id @default(uuid())
  affiliateAccountId String
  amountCents        Int
  currency           String           @default("usd")
  status             String           @default("PENDING")
  requestedAt        DateTime         @default(now())
  processedAt        DateTime?
  payoutRef          String?
  notes              String?
  affiliateAccount   AffiliateAccount @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)

  @@index([affiliateAccountId, status])
}

model AffiliateClick {
  id                 String               @id @default(uuid())
  affiliateAccountId String
  customLinkId       String?
  tenantId           String?
  sessionId          String?
  landingPath        String?
  referrer           String?
  ipHash             String?
  userAgent          String?
  createdAt          DateTime             @default(now())
  affiliateAccount   AffiliateAccount     @relation(fields: [affiliateAccountId], references: [id], onDelete: Cascade)
  customLink         AffiliateCustomLink? @relation(fields: [customLinkId], references: [id], onDelete: SetNull)

  @@index([affiliateAccountId, createdAt])
  @@index([customLinkId, createdAt])
