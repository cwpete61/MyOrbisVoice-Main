model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  username              String?                @unique
  /// Nullable: Google-only sign-in users have no local password. Existing
  /// password users keep their hash. A user can have BOTH (if they signed up
  /// with password then linked Google in profile).
  passwordHash          String?
  /// Stable Google identity (Google's `sub` claim). Lets us re-find a user
  /// even if their Google email changes. Populated on first Google sign-in
  /// (auto-linked to existing user when emails match) or on signup-via-Google.
  googleId              String?                @unique
  firstName             String?
  lastName              String?
  preferredLocale       String                 @default("en")
  /// User's preferred IANA time-zone name (e.g. "America/New_York", "Europe/Madrid").
  /// Null means "follow the browser's detected zone" — set via the Profile page.
  /// Independent of Tenant.timezone (which is the business default for things
  /// like appointment booking + after-hours logic).
  preferredTimezone     String?
  status                UserStatus             @default(ACTIVE)
  lastLoginAt           DateTime?
  /// Optional contact mobile, captured at signup. Used for A2P-compliant
  /// SMS account/service notifications.
  phone                 String?
  /// Set when the user ticks the SMS-consent checkbox (at signup or later).
  /// Null = no SMS consent on record. Drives A2P opt-in proof.
  smsConsentAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenantMemberships     TenantMember[]
  createdPromptVersions PromptVersion[]        @relation("PromptCreatedBy")
  auditLogs             AuditLog[]             @relation("AuditActorUser")
  affiliateAccount      AffiliateAccount?
  startedImpersonations ImpersonationSession[] @relation("ImpersonationStartedBy")
  refreshTokens         RefreshToken[]
  pushSubscriptions     PushSubscription[]
  a2pOperatorNotes      A2POperatorNote[]
  passwordResetTokens   PasswordResetToken[]
  uploadedKbFiles       KnowledgeBaseFile[]    @relation("KbFileUploadedBy")
  featuredDemos         Conversation[]         @relation("DemoFeaturedBy")
  contactNotes          ContactNote[]          @relation("ContactNoteAuthor")
}

model Tenant {
  id                        String                  @id @default(uuid())
  slug                      String                  @unique
  displayName               String
  legalName                 String?
  status                    TenantStatus            @default(TRIAL)
  timezone                  String                  @default("America/New_York")
  registrationEmail         String
  publicEmail               String?
  publicPhone               String?
  website                   String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  deletedAt                 DateTime?
  /// Per-step explicit "I'm done with this onboarding step" markers.
  /// Shape: { profile: true, dna: true, ... } — set by the user clicking
  /// the "Save & Back to Get Started" button on a step page. Acts as an
  /// override on top of the data-based auto-detection so a user who has
  /// configured what they care about can mark a step done even if
  /// non-required fields are blank. Null = nothing manually marked yet.
  onboardingMarkedDone      Json?
  /// Phase G.4 — manual override to re-show the onboarding wizard after it
  /// has auto-hidden on completion. The dashboard banner shows when the
  /// wizard is incomplete OR this flag is true. Partner/tenant flips it from
  /// the profile/settings page.
  showOnboardingWizard      Boolean                 @default(false)
  /// Tracks which onboarding emails have been sent + when. Shape:
  /// { setupNudge: ISO, featureSpotlight: ISO, weekTwoCheckIn: ISO }.
  /// Populated by the onboarding-emails job. Idempotent — once a key is set,
  /// that email is never re-sent.
  onboardingEmailsSent      Json?
  referredByCode            String?
  attributedAt              DateTime?
  industryVertical          IndustryVertical        @default(GENERAL)
  /// Public "DEMO" sandbox tenant. Money/irreversible actions are blocked and the
  /// tenant is periodically reset to its seed (see demo.service + demo-reset job).
  isDemo                    Boolean                 @default(false)
  /// Stripe Connect (Express) — lets the tenant collect payments from THEIR
  /// own customers. Pass-through model: DIRECT charges on this connected
  /// account, no platform application fee (tenant keeps 100%). Distinct from
  /// `stripeCustomerRef` (which is how the PLATFORM bills the tenant).
  stripeConnectAccountId    String?                 @unique
  stripeChargesEnabled      Boolean                 @default(false)
  /// Mirror of the latest Connect account.updated status (detailsSubmitted,
  /// payoutsEnabled, disabledReason, refreshedAt). Write-only status cache.
  stripeConnectStatusJson   Json?
  stripeConnectOnboardedAt  DateTime?
  /// Phase 2 — lets the Orby voice agent offer + collect payment on a call
  /// (texts a Stripe link to the caller). OFF by default; only fires when this
  /// is true AND stripeChargesEnabled. orbyDepositCents = default deposit Orby
  /// offers after a booking (null = Orby asks/uses caller-stated amount).
  orbyPaymentsEnabled       Boolean                 @default(false)
  orbyDepositCents          Int?
  tenantPayments            TenantPayment[]
  members                   TenantMember[]
  businessProfile           BusinessProfile?
  businessDNARecords        BusinessDNA[]
  promptVersions            PromptVersion[]
  agentProfiles             AgentProfile[]
  channelConfigs            ChannelConfig[]
  integrationConnections    IntegrationConnection[]
  stripeCustomerRef         StripeCustomerRef?
  subscriptions             Subscription[]
  phoneNumbers              PhoneNumber[]
  twilioSubaccount          TenantTwilioSubaccount?
  a2pApplication            TenantA2PApplication?
  pushSubscriptions         PushSubscription[]
  contacts                  Contact[]
  contactNotes              ContactNote[]
  pipelineStages            PipelineStage[]
  conversations             Conversation[]
  appointments              Appointment[]
  appointmentReminders      AppointmentReminder[]
  staffMembers              StaffMember[]
  messageLogs               MessageLog[]
  workflowExecutions        WorkflowExecutionRef[]
  tenantEntitlements        TenantEntitlement[]
  affiliateConversions      AffiliateConversion[]
  affiliateCommissions      AffiliateCommission[]
  auditLogs                 AuditLog[]
  impersonationSessions     ImpersonationSession[]
  callLogs                  CallLog[]
  outboundCampaigns         OutboundCampaign[]
  outboundCallAttempts      OutboundCallAttempt[]
  campaigns                 Campaign[]
  campaignEnrollments       CampaignEnrollment[]
  widgetSessions            WidgetSession[]
  twilioEventLogs           TwilioEventLog[]
  storageQuotaBytes         BigInt?
  storageUsedBytes          BigInt                  @default(0)
  storageWarningAckedAt     DateTime?
  recordingBehavior         String                  @default("stop")
  recordingRetentionDays    Int?
  storageTier               String?
  storageGracePeriodEndsAt  DateTime?
  storagePreviousQuotaBytes BigInt?
  optOutLogs                OptOutLog[]
  notifications             Notification[]
  knowledgeBaseFiles        KnowledgeBaseFile[]
  listings                  Listing[]
  /// Cumulative bytes used by knowledge-base files. Maintained by the
  /// upload/delete service. Capped by the `kb_storage_mb` entitlement
  /// (separate pool from voice-recording storageUsedBytes).
  kbStorageUsedBytes        BigInt                  @default(0)
  // Phase F.4 — email reputation
  emailSuppressions         EmailSuppression[]
  emailCampaigns            EmailCampaign[]
}

model TenantMember {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String
  roleDefinitionId String
  isOwner          Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  @@unique([tenantId, userId])
}

model RoleDefinition {
  id             String         @id @default(uuid())
  key            String         @unique
  name           String
  description    String?
  isPlatformRole Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenantMembers  TenantMember[]
}

model Plan {
  id                     String            @id @default(uuid())
  code                   String            @unique
  name                   String
  description            String?
  interval               PlanInterval
  priceCents             Int               @default(0)
  stripePriceId          String?
  /// Optional second Stripe price ID, used for plans that bundle a one-time
  /// charge (`stripePriceId`) PLUS a recurring add-on (this field). Today
  /// only LTD uses this — $497 one-time for lifetime access plus $24.99/mo
  /// for token coverage. Standard plans leave this null.
  stripeRecurringPriceId String?
  /// Public Stripe Payment Link URL for this plan (https://buy.stripe.com/...).
  /// Used by the comp-codes admin page to give admins a one-click share link
  /// that the recipient can open to land directly in Stripe checkout with the
  /// right price loaded — `?prefilled_email=` and `?prefilled_promo_code=`
  /// query params are appended at link-generation time. Created via the
  /// Stripe API once per plan and reused.
  stripeBuyLinkUrl       String?
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  entitlements           PlanEntitlement[]
  subscriptions          Subscription[]
}

model PlanEntitlement {
  id           String               @id @default(uuid())
  planId       String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  plan         Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
}

model TenantEntitlement {
  id           String                @id @default(uuid())
  tenantId     String
  key          String
  valueType    EntitlementValueType
  booleanValue Boolean?
  integerValue Int?
  stringValue  String?
  sourceType   EntitlementSourceType
  sourceRef    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model BusinessProfile {
  id                        String   @id @default(uuid())
  tenantId                  String   @unique
  brandName                 String
  logoUrl                   String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  region                    String?
  postalCode                String?
  country                   String?
  serviceAreasJson          Json?
  // Working hours for the agent / booking engine. Short-key shape:
  //   { mon: { open: "09:00", close: "17:00" }, tue: {...}, sun: null }
  // Days omitted or set to null are closed. Drives searchAvailability for
  // non-partner bookings (the partner equivalent is AffiliateAccount.bookingHoursJson).
  businessHoursJson         Json?
  // Phase E.5 — tenant-side booking preferences. Mirror of the partner fields
  // on AffiliateAccount (E.3) so a tenant's own booking flow honors the same
  // notice / advance / buffer / slot rules without the agent having to guess.
  bookingSlotDurationMin    Int      @default(30)
  bookingMinNoticeMin       Int      @default(60)
  bookingMaxAdvanceDays     Int      @default(60)
  bookingBufferBeforeMin    Int      @default(0)
  bookingBufferAfterMin     Int      @default(0)
  // Phase E.6 — appointment reminder configuration. When enabled, every new
  // booking with a contact email + reminderEmailEnabled (or contact phone +
  // reminderSmsEnabled) gets an AppointmentReminder row per configured offset.
  // Defaults: send 24h + 1h before, both channels on. The reminder-runner job
  // polls AppointmentReminder.PENDING rows and dispatches via the existing
  // email + SMS services. See apps/api/src/jobs/reminder-runner.ts.
  reminderEnabled           Boolean  @default(true)
  reminderOffsetsMin        Int[]    @default([1440, 60]) // 24h + 1h before
  reminderEmailEnabled      Boolean  @default(true)
  reminderSmsEnabled        Boolean  @default(true)
  // Phase E.8 — reminder copy customization. Optional overrides for the
  // built-in reminder templates. NULL = use defaults. Variables supported:
  // {firstName} {businessName} {appointmentType} {whenLabel} {dateStr}
  // {timeStr} {location}. See reminder.service.ts:renderTemplate.
  reminderEmailSubject      String?  @db.VarChar(200)
  reminderEmailIntro        String?  @db.VarChar(1000)
  reminderSmsBody           String?  @db.VarChar(320)
  fallbackNotificationEmail String?
  // Marketing voice intensity ('conservative' | 'balanced' | 'direct' | 'aggressive').
  // Drives AI-Assist generated copy, default campaign tone, and outbound voice agent
  // intensity. See docs/marketing-style-guide.md for the spectrum definition.
  aggressionTier            String   @default("balanced")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessDNA {
  id              String   @id @default(uuid())
  tenantId        String
  identityJson    Json
  servicesJson    Json
  pricingJson     Json
  operationsJson  Json
  salesJson       Json
  appointmentJson Json
  supportJson     Json
  languageJson    Json
  complianceJson  Json
  version         Int
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
}

/// Tenant-uploaded reference documents the AI agent can use as background
/// knowledge during conversations. File blobs live on Bunny under
/// `tenants/{tenantId}/knowledge-base/{id}.{ext}`. Extracted text lives in
/// this row's `extractedText` so the agent never round-trips to Bunny on
/// the live-call path. Capped per-tenant by the `kb_storage_mb`
/// entitlement; per-file size capped by KB_MAX_FILE_BYTES in code.
model KnowledgeBaseFile {
  id               String       @id @default(uuid())
  tenantId         String
  filename         String
  mimeType         String
  sizeBytes        Int
  bunnyStorageKey  String       @unique
  extractedText    String?
  extractionStatus KbFileStatus @default(PENDING)
  errorMessage     String?
  uploadedById     String
  uploadedAt       DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("KbFileUploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId, extractionStatus])
  @@index([tenantId, uploadedAt])
}

enum KbFileStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model PromptVersion {
  id              String          @id @default(uuid())
  tenantId        String?
  scope           PromptScope
  channelType     ChannelType?
  agentRoleType   AgentRoleType?
  name            String
  content         String
  status          PromptStatus    @default(DRAFT)
  versionNumber   Int             @default(1)
  parentPromptId  String?
  createdByUserId String?
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenant          Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentPrompt    PromptVersion?  @relation("PromptParent", fields: [parentPromptId], references: [id], onDelete: SetNull)
  childPrompts    PromptVersion[] @relation("PromptParent")
  createdByUser   User?           @relation("PromptCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  agentProfiles   AgentProfile[]
  channelConfigs  ChannelConfig[]

  @@index([tenantId, scope])
  @@index([tenantId, status])
}

model AgentProfile {
  id              String            @id @default(uuid())
  // Exactly one of tenantId / partnerId is set. Tenant-scoped agents serve
  // calls hitting a tenant's numbers; partner-scoped agents serve calls
  // hitting a partner's numbers (Phase G.1+). Routing dispatches off
  // PhoneNumber.partnerId vs .tenantId at the webhook layer.
  tenantId        String?
  partnerId       String?
  agentRoleType   AgentRoleType
  displayName     String
  isEnabled       Boolean           @default(false)
  modelProvider   String
  modelName       String
  promptVersionId String?
  settingsJson    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // Soft-delete anchor. NULL = active. Set to a timestamp when the agent is
  // "deleted" — record stays in DB so it can be restored by clearing the
  // field. Default list queries filter `WHERE deletedAt IS NULL`.
  deletedAt       DateTime?
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner         AffiliateAccount? @relation("PartnerAgentProfiles", fields: [partnerId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion?    @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  phoneNumbers    PhoneNumber[]

  @@unique([tenantId, agentRoleType])
  @@unique([partnerId, agentRoleType])
}

model ChannelConfig {
  id              String         @id @default(uuid())
  tenantId        String
  channelType     ChannelType
  isEnabled       Boolean        @default(false)
  publicKey       String?        @unique
  greetingMode    String?
  afterHoursMode  String?
  escalationMode  String?
  configJson      Json?
  promptVersionId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, channelType])
}

model IntegrationConnection {
  id                  String                  @id @default(uuid())
  tenantId            String?
  provider            IntegrationProvider
  status              IntegrationStatus       @default(NOT_CONNECTED)
  label               String
  externalAccountId   String?
  externalEmail       String?
  metadataJson        Json?
  lastVerifiedAt      DateTime?
  reconnectRequiredAt DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  googleDetail        GoogleConnectionDetail?
  twilioDetail        TwilioConnectionDetail?
  staffMember         StaffMember?
  // Set when this connection is owned by an AffiliateAccount (per-partner
  // Google calendar). Mutually exclusive with tenant/staff ownership at the
  // application layer — exactly one of (tenant, staffMember, affiliateAccount)
  // should be populated per row.
  affiliateAccount    AffiliateAccount?       @relation("PartnerGoogle")
}

model GoogleConnectionDetail {
  id                      String                @id @default(uuid())
  integrationConnectionId String                @unique
  mailboxEmail            String
  grantedScopesJson       Json
  calendarIdsJson         Json?
  tokenExpiresAt          DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model TwilioConnectionDetail {
  id                      String                @id @default(uuid())
  integrationConnectionId String                @unique
  accountSid              String
  encryptedAuthToken      String?
  messagingServiceSid     String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
}

model StripeCustomerRef {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// A payment the tenant collects from one of THEIR OWN customers via Stripe
/// Connect — a pass-through DIRECT charge on the tenant's connected account
/// (no platform fee). Created PENDING when a Checkout/payment link is generated,
/// flipped PAID by the Connect webhook (checkout.session.completed /
/// payment_intent.succeeded, matched on stripeCheckoutId / stripePaymentIntentId).
/// contactId is a soft reference (no FK) to keep the blast radius small.
model TenantPayment {
  id                    String    @id @default(uuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId             String?   // soft ref to Contact
  appointmentId         String?   // soft ref to Appointment (booking deposit)
  amountCents           Int
  currency              String    @default("usd")
  description           String?
  status                String    @default("PENDING") // PENDING | PAID | CANCELED | FAILED
  stripeCheckoutId      String?   @unique
  stripePaymentIntentId String?   @unique
  checkoutUrl           String?   @db.Text
  source                String    @default("manual") // manual | booking | voice
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// Phase G.1.B-2 — Partner-side Stripe Customer mapping. Mirrors the tenant
// variant. Each partner who buys any paid resource (phone number today,
// other paid features later) gets one Stripe Customer + that's where their
// saved cards + Subscriptions live.
model PartnerStripeCustomerRef {
  id               String           @id @default(uuid())
  partnerId        String           @unique
  stripeCustomerId String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  partner          AffiliateAccount @relation("PartnerStripeCustomer", fields: [partnerId], references: [id], onDelete: Cascade)
}

/// Phase G.2 — Append-only ledger of every SMS-credit movement on a partner.
/// PURCHASE rows are written from the Stripe checkout.session.completed
/// webhook; CONSUME rows by the messaging service before each outbound send;
/// REFUND when a send fails post-deduct; ADJUST is the admin override path.
/// AffiliateAccount.smsCreditBalance is the running total — every row writes
/// the balanceAfter snapshot for forensic reconstruction.
model PartnerSmsCreditLedger {
  id                    String                   @id @default(uuid())
  partnerId             String
  eventType             PartnerSmsCreditEvent
  creditsDelta          Decimal                  @db.Decimal(10, 2) // positive on grant, negative on consume
  balanceAfter          Decimal                  @db.Decimal(10, 2)
  /// Channel of the message that triggered this row (CONSUME/REFUND only).
  /// Null for PURCHASE / ADJUST.
  channel               PartnerSmsCreditChannel?
  /// Stripe price metadata pack id ("pack_5" / "pack_10") for PURCHASE rows.
  packId                String?
  usdAmountCents        Int? // PURCHASE: pack price; CONSUME: null
  /// Phase G.2.1 — actual Twilio cost (USD cents) captured from the sms-status
  /// webhook's Price field. Used to compute net pack profitability per partner
  /// so we can flag partners whose real Twilio spend approaches their pack
  /// purchase total (margin protection). Populated only on CONSUME rows; null
  /// when the message hasn't reached a terminal Twilio status yet.
  twilioCostCents       Decimal?                 @db.Decimal(10, 4)
  stripePaymentIntentId String?                  @unique
  stripeSessionId       String?                  @unique
  messageLogId          String? // CONSUME: FK to MessageLog.id (no DB-level constraint to keep it loose)
  note                  String?
  createdAt             DateTime                 @default(now())

  partner AffiliateAccount @relation("PartnerSmsCreditLedger", fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([eventType])
  @@index([messageLogId])
}

enum PartnerSmsCreditEvent {
  PURCHASE // Stripe one-time payment cleared
  CONSUME // outbound message deducted credits
  REFUND // CONSUME reversed (send failed post-deduct)
  ADJUST // admin manual adjustment (audit-logged elsewhere)
}

enum PartnerSmsCreditChannel {
  SMS // 1 segment SMS
  SMS_LONG // 2-segment SMS = 2 credits
  MMS // 2.5 credits
  WHATSAPP // reserved — pricing TBD
}

/// Phase G.3 — per-call voice usage meter for partner numbers.
///
/// Voice minutes are billed POST-PAID, separate from the $2/mo flat number
/// rental. Each completed call on a partner number writes one row here and
/// (idempotently) a Stripe invoice item against the partner's customer; the
/// pending invoice item auto-attaches to the partner's next monthly number
/// subscription invoice — i.e. "billed at the end of the 30-day cycle".
///
/// Rate card (cents per billed minute, minutes rounded up):
///   LOCAL    inbound/outbound = 2¢
///   TOLLFREE inbound/outbound = 3¢
model PartnerVoiceUsageLedger {
  id                  String                 @id @default(uuid())
  partnerId           String
  phoneNumberId       String
  /// Twilio CallSid — unique so a repeated status webhook can't double-bill.
  callSid             String                 @unique
  direction           PartnerVoiceDirection
  numberType          PartnerVoiceNumberType
  durationSeconds     Int
  billableMinutes     Int // ceil(durationSeconds / 60), min 1 for a connected call
  ratePerMinuteCents  Int
  amountCents         Int // billableMinutes * ratePerMinuteCents
  /// Actual Twilio cost (USD cents) from the status callback Price field, when
  /// present. Lets us reconcile real cost vs. billed amount for margin checks.
  twilioCostCents     Decimal?               @db.Decimal(10, 4)
  /// Stripe invoice item created for this call. Unique — the dedupe anchor for
  /// the billing side (callSid dedupes the ledger row; this dedupes Stripe).
  stripeInvoiceItemId String?                @unique
  billedAt            DateTime? // set when the invoice item is created
  createdAt           DateTime               @default(now())

  partner AffiliateAccount @relation("PartnerVoiceUsage", fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([phoneNumberId])
}

enum PartnerVoiceDirection {
  INBOUND
  OUTBOUND
}

enum PartnerVoiceNumberType {
  LOCAL
  TOLLFREE
}

/// Idempotency ledger for Stripe webhooks. Stripe delivers events with
/// at-least-once semantics — the same event.id can arrive 2+ times if their
/// retry logic fires. Without dedup, our handlers would write duplicate audit
/// rows + run downstream side-effects twice (notifications, future emails,
/// etc). The handler short-circuits if it sees an event.id already in this
/// table.
///
/// We don't need to retain forever — purging rows older than 30 days is safe
/// since Stripe stops retrying after ~3 days. Keep 30 for forensic margin.
model StripeWebhookEvent {
  /// The Stripe event.id (e.g. "evt_1ABC..."). Primary key — the dedupe key.
  eventId    String   @id
  /// Event type for forensic search ("customer.subscription.updated" etc).
  type       String
  /// Wall-clock receive time. Index supports the periodic cleanup query.
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
}

model PhoneNumber {
  id                  String    @id @default(uuid())
  // tenantId is always set — partner-owned numbers point at the platform
  // tenant ("orbis-platform") so existing tenant-keyed queries don't break.
  // partnerId is the partner-ownership tag: when set, webhook dispatch routes
  // the call to the partner's agent context (not the platform tenant's).
  tenantId            String
  partnerId           String?
  // Agent that answers inbound calls to this number. For partner-acquired
  // numbers this is set to the platform-controlled master "Orby" agent on
  // purchase; the partner can later re-point it (overridable default).
  // Null = fall back to the default scope resolution at the webhook layer.
  agentProfileId      String?
  twilioNumberSid     String?
  twilioSubaccountSid String? // null = on master account; populated once subaccount exists
  // No longer @unique — multiple PENDING/REJECTED requests for the same
  // E.164 are valid; only PURCHASED rows must be unique. Enforced in code.
  e164Number          String
  displayLabel        String?
  monthlyPriceCents   Int? // captured at purchase time so we can show it without re-querying Twilio
  notes               String? // tenant-facing free-text note for the number (e.g. "main reception")
  isInboundEnabled    Boolean   @default(false)
  isOutboundEnabled   Boolean   @default(false)
  isSmsEnabled        Boolean   @default(false)
  forwardingTarget    String?
  // Cancellation grace period — when set, number is marked for release at this time.
  // Background job (or check-on-fetch) releases it when reached.
  releaseScheduledAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ── Partner purchase lifecycle (Phase G.1.B) ────────────────────────────
  // Tenant-owned numbers go straight to PURCHASED on creation; partner-owned
  // numbers go PENDING → APPROVED → PURCHASED through the admin queue.
  // RELEASED happens when the number is sent back to Twilio.
  purchaseStatus        PhoneNumberPurchaseStatus @default(PURCHASED)
  // Capability tier sets the monthly price + which features unlock.
  // Null for tenant numbers (tenant has its own pricing model).
  partnerCapabilityTier PartnerNumberTier?
  // A2P 10DLC status for SMS-enabled numbers. NOT_REQUIRED means voice-only
  // (no SMS) or toll-free (different verification flow).
  a2pStatus             A2pStatus                 @default(NOT_REQUIRED)
  requestedAt           DateTime?
  requestedByUserId     String?
  approvedAt            DateTime?
  approvedByUserId      String?
  rejectionReason       String?
  // Phase G.1.B-2 — Stripe Subscription that auto-renews this number's
  // monthly charge. Set when admin approves the number. Null for non-partner
  // numbers and historic rows. Cancellation = number gets released to Twilio.
  stripeSubscriptionId  String?

  // MyOrbisAgents — when set, this number is a per-listing tracking number:
  // inbound calls attribute to the listing and Orby focuses on it (§17c/§17b).
  listingId    String?

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner      AffiliateAccount? @relation("PartnerPhoneNumbers", fields: [partnerId], references: [id], onDelete: Cascade)
  agentProfile AgentProfile?     @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)
  listing      Listing?          @relation("ListingTrackingNumber", fields: [listingId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([partnerId])
  @@index([purchaseStatus])
  @@index([listingId])
}

// Lifecycle for a PhoneNumber row. Existing tenant numbers default to
// PURCHASED on backfill; new partner requests start at PENDING.
enum PhoneNumberPurchaseStatus {
  PENDING // partner requested, awaiting admin approval
  APPROVED // admin approved, Twilio purchase pending (transient)
  PURCHASED // bought from Twilio, twilioNumberSid populated
  REJECTED // admin rejected — request killed
  RELEASED // returned to Twilio
}

// Capability tier — drives monthly price + features available on the number.
enum PartnerNumberTier {
  VOICE // $2/mo  US local, voice in+out, no SMS
  VOICE_SMS // $15/mo US local, voice + SMS, includes A2P brand + campaign
  TOLLFREE // $5/mo  toll-free, voice + SMS (no A2P required, separate verification)
}

// A2P 10DLC registration state for the partner number's brand + campaign.
enum A2pStatus {
  NOT_REQUIRED // voice-only OR toll-free — no A2P registration applies
  PENDING_QUEUE // partner asked for SMS — sitting in admin queue
  SUBMITTED // admin submitted to Twilio Trust Hub, awaiting review
  APPROVED // Twilio approved — SMS enabled
  REJECTED // Twilio rejected — partner needs to fix something
}

// One row per tenant — created lazily on the tenant's FIRST number purchase.
// Stores the Twilio subaccount SID + encrypted subaccount auth token.
// Numbers, brands, billing in Twilio are scoped to this subaccount.
model TenantTwilioSubaccount {
  id                           String                 @id @default(uuid())
  tenantId                     String                 @unique
  twilioSubaccountSid          String                 @unique
  encryptedSubaccountAuthToken String
  status                       TwilioSubaccountStatus @default(ACTIVE)
  // Set when tenant cancels their subscription. After cancellationGraceUntil
  // expires we release all the subaccount's resources and close it.
  cancellationGraceUntil       DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  tenant                       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum TwilioSubaccountStatus {
  ACTIVE
  PENDING_CLOSURE // grace period running
  CLOSED // closed on Twilio's side
  SUSPENDED // platform-side suspension (abuse, etc.)
}

// Phase G.1 — Partner Twilio subaccount. One row per partner, lazy-created
// on the partner's first phone-number purchase. Mirrors the Tenant variant
// so partner and tenant flows can share helpers via discriminated dispatch.
// Numbers, brands, billing scoped to this subaccount = full per-partner
// isolation (legal-entity compliance for A2P + abuse handling).
model PartnerTwilioSubaccount {
  id                           String                 @id @default(uuid())
  partnerId                    String                 @unique
  twilioSubaccountSid          String                 @unique
  encryptedSubaccountAuthToken String
  status                       TwilioSubaccountStatus @default(ACTIVE)
  cancellationGraceUntil       DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  partner                      AffiliateAccount       @relation("PartnerTwilioSubaccount", fields: [partnerId], references: [id], onDelete: Cascade)
}

// A2P 10DLC application — captured per tenant for SMS compliance.
// Submission to Twilio Trust Hub APIs is gated on platform's ISV approval;
// until then this stores the data so we can submit in bulk once unblocked.
model TenantA2PApplication {
  id                        String               @id @default(uuid())
  /// Scope key. Exactly one of tenantId / partnerId is set, or both null
  /// for the platform-scope row (MyOrbisVoice's own A2P registration on the
  /// master Twilio account). tenantId-scope = a tenant's registration;
  /// partnerId-scope = a partner's registration for their managed numbers.
  /// At most one row per tenant, per partner, and one platform-scope row.
  tenantId                  String?              @unique
  partnerId                 String?              @unique
  legalName                 String // exact business legal name (matches EIN registration)
  ein                       String? // US EIN — optional for sole-prop
  businessType              String // SOLE_PROP / LLC / CORP / NON_PROFIT etc.
  vertical                  String // healthcare, retail, professional_services, etc.
  websiteUrl                String?
  addressLine1              String
  addressLine2              String?
  city                      String
  region                    String // state for US
  postalCode                String
  country                   String               @default("US")
  contactFirstName          String
  contactLastName           String
  contactEmail              String
  contactPhone              String
  useCase                   String // marketing / mixed / customer_care / 2fa / utility
  sampleMessagesJson        Json // array of 5 sample SMS bodies
  // Trust Hub pipeline SIDs — populated step-by-step as the submission
  // engine advances. All null until submit; each persists once its step
  // succeeds so the engine is resumable.
  twilioCustomerProfileSid  String? // Secondary Customer Profile bundle
  twilioTrustProductSid     String? // A2P TrustProduct (Trust Bundle)
  twilioBrandSid            String? // BrandRegistration
  twilioMessagingServiceSid String? // Messaging Service the campaign attaches to
  twilioCampaignSid         String? // UsAppToPerson Campaign
  // 'mock' (default — Twilio mock APIs / local simulation, no TCR billing,
  // no live SMS) or 'live' (real Trust Hub submission). A live submission
  // is only allowed once an operator flips this explicitly.
  submissionMode            String               @default("mock")
  status                    A2PApplicationStatus @default(DRAFT)
  rejectionReason           String?
  // 4-layer validation gate output — the full report (per-layer pass/fail,
  // findings, AI compliance notes). Refreshed each time the gate runs.
  validationReportJson      Json?
  validatedAt               DateTime?
  // Explicit customer authorization (gate layer 4). The submission engine
  // refuses to run until this is set — the app must not submit on the
  // customer's behalf without recorded consent.
  authorizedAt              DateTime?
  authorizedByUserId        String?
  submittedAt               DateTime?
  approvedAt                DateTime?
  lastTwilioSyncAt          DateTime? // last time status was polled/synced from Twilio
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  tenant                    Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner                   AffiliateAccount?    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  operatorNotes             A2POperatorNote[]
}

// A2P application lifecycle — modeled as a state machine, not a single
// blind request (see docs/twilio-a2p-automation.md). The submission engine
// advances the row through these as Twilio Trust Hub / Brand / Campaign
// review progresses.
enum A2PApplicationStatus {
  DRAFT // filling the form
  VALIDATING // 4-layer pre-submission gate running
  VALIDATION_FAILED // gate rejected — see validationReportJson
  READY_TO_SUBMIT // gate passed + customer authorized, awaiting submit
  SUBMITTED // posted to Twilio Trust Hub
  PROFILE_PENDING // Customer Profile / TrustProduct in review
  BRAND_PENDING // BrandRegistration submitted, awaiting approval
  BRAND_FAILED // Brand rejected by TCR
  BRAND_APPROVED // Brand approved — campaign submission next
  CAMPAIGN_PENDING // UsAppToPerson Campaign submitted, in review
  APPROVED // Brand + Campaign approved — numbers can send SMS at full throughput
  REJECTED // terminal rejection
  SUSPENDED // Brand/Campaign suspended after approval
}

/// Append-only friction log for A2P submissions. Operators add a note every
/// time they have to email a tenant for clarification, find a missing field,
/// hit a Twilio rejection, etc. After ~20 submissions this becomes the
/// data-driven design input for the future self-service A2P wizard.
model A2POperatorNote {
  id            String                  @id @default(uuid())
  applicationId String
  byUserId      String // admin user who wrote the note
  category      A2POperatorNoteCategory
  note          String // free-form description, max ~2000 chars enforced at API layer
  createdAt     DateTime                @default(now())
  application   TenantA2PApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  byUser        User                    @relation(fields: [byUserId], references: [id], onDelete: Restrict)

  @@index([applicationId, createdAt])
  @@index([category])
}

enum A2POperatorNoteCategory {
  CLARIFICATION_NEEDED // had to email tenant for more info
  DATA_GAP // tenant left a required field blank or stub
  FORMAT_ERROR // tenant entered something in wrong format (EIN, phone, URL)
  USE_CASE_MISMATCH // sample messages don't match declared use case
  COMPLIANCE_CONCERN // pre-emptive flag — Twilio likely to reject if submitted as-is
  OTHER
}

/// Public SMS opt-in — one row per submission of the "Get text updates"
/// form on the marketing site (myorbisvoice.com/sms-updates.html). This is
/// the A2P 10DLC consent record: it stores the exact disclosure text the
/// person agreed to, so the opt-in is verifiable if a carrier disputes it.
model SmsOptIn {
  id          String   @id @default(uuid())
  phone       String
  name        String?
  consentText String // the exact consent-disclosure wording shown + agreed to
  sourceUrl   String? // page the form was submitted from
  locale      String   @default("en")
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

// Web Push subscription — one row per browser/device. Created when the user
// grants permission. Used to fire desktop notifications on call events.
model PushSubscription {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  endpoint   String   @unique
  p256dh     String // browser public key for E2E encryption
  auth       String // browser auth secret
  userAgent  String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Contact {
  id                      String                   @id @default(uuid())
  tenantId                String
  firstName               String?
  lastName                String?
  fullName                String?
  email                   String?
  phoneE164               String?
  addressLine1            String?
  city                    String?
  region                  String?
  postalCode              String?
  country                 String?
  source                  String
  tagsJson                Json?
  metadataJson            Json?
  emailStatus             String?
  emailVerifiedAt         DateTime?
  phoneStatus             String?
  phoneVerifiedAt         DateTime?
  agentConfirmedAt        DateTime?
  optedOutSms             Boolean                  @default(false)
  optedOutSmsAt           DateTime?
  optedOutVoice           Boolean                  @default(false)
  optedOutVoiceAt         DateTime?
  optedOutEmail           Boolean                  @default(false)
  optedOutEmailAt         DateTime?
  optedOutWhatsapp        Boolean                  @default(false)
  optedOutWhatsappAt      DateTime?
  // CRM relationship fields — collected during OUTBOUND campaigns only.
  // The inbound agent is instructed never to ask for these (privacy + flow).
  // Outbound campaigns can opt-in per-campaign by listing fields to collect.
  birthday                DateTime? // anchor date; year is informational only
  anniversary             DateTime? // wedding / relationship anniversary
  spouseName              String?
  kidsInfoJson            Json? // [{ name, age?, birthday?, notes? }]
  petsInfoJson            Json? // [{ name, type, age?, notes? }]
  importantDatesJson      Json? // [{ label, date, notes? }] — arbitrary recurring dates
  hobbies                 String? // freeform / comma-separated interests
  preferredContactTime    String? // 'morning' | 'afternoon' | 'evening' | freeform
  customerSince           DateTime?
  personalNotes           String? // freeform internal-only notes (legacy single-field; ContactNote thread is the active surface)
  // Phase F.1 — CRM pipeline. Optional; null when the contact hasn't been
  // placed on a pipeline yet (e.g. seed data from before the feature shipped).
  // stageUpdatedAt is the timestamp of the LAST stage change — drives the
  // "X days in stage" indicator on the kanban + flags stuck deals.
  pipelineStageId         String?
  stageUpdatedAt          DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  // Soft-delete anchor (data-loss prevention). When set, the contact is
  // hidden from list/search queries but remains in the DB so it can be
  // restored. Hard-delete is reserved for admin-side compliance purges.
  deletedAt               DateTime?
  // Phase F.3 — partner-scoped CRM. When this contact was captured via a
  // partner's landing-page widget, partnerId points at that AffiliateAccount.
  // tenantId remains the hosting tenant (currently the platform demo tenant)
  // but the partner CRM filters on partnerId so partners only see their own
  // leads. Null partnerId → tenant-side contact, surfaced in the tenant CRM.
  partnerId               String?
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner                 AffiliateAccount?        @relation("PartnerContacts", fields: [partnerId], references: [id], onDelete: SetNull)
  pipelineStage           PipelineStage?           @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  conversations           Conversation[]
  appointments            Appointment[]
  appointmentReminders    AppointmentReminder[]
  messageLogs             MessageLog[]
  callLogs                CallLog[]
  outboundAttempts        OutboundCallAttempt[]
  campaignEnrollments     CampaignEnrollment[]
  optOutLogs              OptOutLog[]
  notes                   ContactNote[]
  emailCampaignRecipients EmailCampaignRecipient[]

  @@index([tenantId, email])
  @@index([tenantId, phoneE164])
  @@index([tenantId, pipelineStageId])
  @@index([partnerId, pipelineStageId])
}

// ─── Phase F.1 — CRM pipeline ───────────────────────────────────────────────
// Per-tenant configurable pipeline. Each tenant gets a default 7-stage
// voice-agent funnel seeded on creation; they can rename, reorder, add, and
// soft-delete stages from the admin UI. PipelineStage rows are the source of
// truth for kanban column ordering.

model PipelineStage {
  id        String            @id @default(uuid())
  tenantId  String
  // Phase F.3 — partner-scoped pipeline. When non-null, this stage belongs to
  // a partner's CRM (independent from any tenant's pipeline that may also use
  // the same hosting tenantId). Tenant stages have partnerId NULL.
  partnerId String?
  name      String            @db.VarChar(80)
  sortOrder Int // ascending — kanban renders left-to-right by this
  color     String?           @db.VarChar(40) // CSS color string (hex or oklch)
  // Terminal flags — when set, contacts in this stage are excluded from
  // "active pipeline" filters and surfaced under Won / Lost reports.
  isWon     Boolean           @default(false)
  isLost    Boolean           @default(false)
  // System-seeded stages are protected from delete (can rename + reorder).
  // Tenants can delete their custom stages freely once empty.
  isSystem  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner   AffiliateAccount? @relation("PartnerPipelineStages", fields: [partnerId], references: [id], onDelete: Cascade)
  contacts  Contact[]

  // The previous `@@unique([tenantId, sortOrder])` is gone because partners
  // share a hosting tenantId and would collide. Application-level two-pass
  // parking in upsertPipelineStages enforces uniqueness within scope.
  @@index([tenantId, partnerId, sortOrder])
  @@index([partnerId])
}

// ─── Phase F.2 — CRM notes thread ───────────────────────────────────────────
// Replaces (alongside, for backwards-compat) Contact.personalNotes. One row
// per note, append-only feed on the contact detail page. authorUserId nullable
// so system-generated notes (auto-transition records, integration sync notes)
// can be attributed to no human author.

model ContactNote {
  id           String            @id @default(uuid())
  tenantId     String
  // Phase F.3 — denormalized for fast partner-scoped queries. Mirrors the
  // owning Contact.partnerId at write time.
  partnerId    String?
  contactId    String
  authorUserId String? // null = system-generated
  body         String            @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner      AffiliateAccount? @relation("PartnerContactNotes", fields: [partnerId], references: [id], onDelete: Cascade)
  contact      Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User?             @relation("ContactNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([contactId, createdAt])
  @@index([tenantId, createdAt])
  @@index([partnerId, createdAt])
}

model Conversation {
  id                    String                @id @default(uuid())
  tenantId              String
  contactId             String?
  channelType           ChannelType
  direction             ConversationDirection
  status                ConversationStatus
  startedAt             DateTime
  endedAt               DateTime?
  summaryText           String?
  transcriptRef         String?
  transcriptJson        Json?
  outcomeCode           String?
  outcomeJson           Json?
  externalCallId        String?
  recordingRef          String?
  recordingBunnyPath    String?
  recordingDurationSecs Int?
  recordingStatus       String?
  recordingSizeBytes    BigInt?
  /// Free-form metadata about the call: per-turn latency, diagnostic flags, etc.
  /// Read by the latency-report CLI; written by the voice gateway on call finalize.
  metadataJson          Json?

  // ── AI conversation monitor ───────────────────────────────────────────────
  // Set on call finalize by the gateway's post-call AI pass. Drives the
  // colour + alerting on the admin central call log: ALERT = a customer
  // issue an admin should look at, WATCH = mild concern, NONE = normal call.
  attentionLevel  ConversationAttentionLevel @default(NONE)
  attentionReason String? // one-line reason when WATCH/ALERT; null otherwise

  // ── Partner context (Phase E.2) ───────────────────────────────────────────
  // Set when this conversation originated on a partner's landing page widget.
  // Drives where book_appointment writes: partnerId set → partner's Google
  // Calendar; partnerId null → tenant's Google Calendar (the existing flow).
  partnerId String?

  // ── Demo Gallery (Phase D.1) ──────────────────────────────────────────────
  // Conversations curated by admin as public demos at /demos/<id>.
  // featuredSummary / featuredTranscript override the raw fields when set,
  // letting admin redact PII before publishing without losing the originals.
  isFeaturedDemo     Boolean   @default(false)
  featuredTitle      String? // e.g. "Bright Smile Dental — after-hours booking"
  featuredCategory   String? // dental | legal | hvac | beauty | fitness | real-estate | coaching | medical
  featuredSortOrder  Int       @default(100)
  featuredAt         DateTime?
  featuredById       String? // FK to User (admin who curated it)
  featuredSummary    String? // redacted display summary (falls back to summaryText)
  featuredTranscript Json? // redacted transcript (falls back to transcriptJson)
  featuredViewCount  Int       @default(0)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  /// MyOrbisAgents — set when the call came in on a listing's tracking number.
  /// Drives per-listing call attribution ("your listing got 14 calls").
  listingId            String?

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact              Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  featuredBy           User?                 @relation("DemoFeaturedBy", fields: [featuredById], references: [id], onDelete: SetNull)
  partner              AffiliateAccount?     @relation("PartnerConversations", fields: [partnerId], references: [id], onDelete: SetNull)
  listing              Listing?              @relation("ListingConversation", fields: [listingId], references: [id], onDelete: SetNull)
  appointments         Appointment[]
  messageLogs          MessageLog[]
  callLogs             CallLog[]
  outboundCallAttempts OutboundCallAttempt[]

  @@index([tenantId, startedAt])
  @@index([tenantId, channelType])
  @@index([externalCallId])
  @@index([isFeaturedDemo, featuredCategory, featuredSortOrder])
  @@index([partnerId])
  @@index([listingId])
}

model StaffMember {
  id                      String                 @id @default(uuid())
  tenantId                String
  name                    String
  title                   String?
  department              String?
  email                   String?
  phone                   String?
  timezone                String?
  phoneExtension          String?
  availabilityJson        Json?
  integrationConnectionId String?                @unique
  calendarId              String?
  isActive                Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationConnection   IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id], onDelete: SetNull)
  appointments            Appointment[]

  @@index([tenantId])
}

model Appointment {
  id              String                @id @default(uuid())
  tenantId        String
  contactId       String?
  conversationId  String?
  staffMemberId   String?
  // Phase E.2 — bookings originating from a partner's landing-page widget are
  // written to the partner's own Google Calendar, NOT the tenant's. The
  // tenantId stays set (the platform demo tenant owns the DB row for admin
  // visibility); partnerId identifies which partner's calendar holds the
  // matching Google event. Null on every non-partner-page appointment.
  partnerId       String?
  status          AppointmentStatus
  appointmentType String?
  startAt         DateTime
  endAt           DateTime
  timezone        String
  providerEventId String?
  location        String?
  notes           String?
  /// Set when the customer ticked the SMS-consent checkbox on the public
  /// booking page — A2P opt-in proof for appointment-reminder texts.
  smsConsentAt    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation    Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  staffMember     StaffMember?          @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  partner         AffiliateAccount?     @relation("PartnerAppointments", fields: [partnerId], references: [id], onDelete: SetNull)
  reminders       AppointmentReminder[]

  @@index([partnerId])
}

// ─── Phase E.6 — Appointment reminders ──────────────────────────────────────
// Decoupled from the campaign system so reminders fire without requiring the
// tenant to configure a campaign. One row per (appointment, channel, offset).
// The reminder-runner job polls PENDING rows where scheduledAt <= now and
// dispatches through the existing email + SMS services. Offsets + channel
// toggles live on BusinessProfile so the tenant edits them in /settings.

enum ReminderChannel {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED // appointment was cancelled or rescheduled before the reminder fired
}

model AppointmentReminder {
  id            String          @id @default(uuid())
  tenantId      String
  appointmentId String
  contactId     String
  channel       ReminderChannel
  offsetMin     Int // minutes before appointment.startAt — kept for audit / debug
  scheduledAt   DateTime // = appointment.startAt - offsetMin
  status        ReminderStatus  @default(PENDING)
  sentAt        DateTime?
  errorReason   String?
  attemptCount  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, channel, offsetMin]) // one reminder per (channel, offset) per appointment
  @@index([status, scheduledAt]) // scheduler hot path
  @@index([tenantId, scheduledAt])
}

model MessageLog {
  id                String            @id @default(uuid())
  tenantId          String
  contactId         String?
  conversationId    String?
  enrollmentId      String?
  channel           MessageChannel
  direction         MessageDirection
  sender            String
  recipient         String
  subject           String?
  bodyText          String?
  bodyRef           String?
  providerMessageId String?
  deliveryStatus    String?
  segmentCount      Int?
  mediaCount        Int?
  billedCents       Int?
  twilioCostCents   Int?
  errorCode         String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  // Phase F.4 — email reputation tracking. Populated from ESP webhooks
  // (Postmark for transactional, Resend for bulk). Hard bounces and
  // complaints auto-add the recipient to EmailSuppression so subsequent
  // sends to the same address skip cleanly.
  bouncedAt         DateTime?
  bounceType        String? // 'hard' | 'soft' — null when no bounce
  bounceReason      String? // ESP-provided description
  complainedAt      DateTime?
  optOutDetected    Boolean           @default(false)
  // Phase F.4 — partnerId mirrored from owning Contact at write time so
  // partner-scoped queries (campaign stats, per-partner bounce rate) don't
  // need to join through Contact every time.
  partnerId         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner           AffiliateAccount? @relation("PartnerMessageLogs", fields: [partnerId], references: [id], onDelete: SetNull)
  contact           Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation      Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, channel, direction, createdAt])
  @@index([tenantId, contactId])
  @@index([partnerId, channel, createdAt])
  @@index([providerMessageId])
}

model CallLog {
  id                String                @id @default(uuid())
  tenantId          String
  contactId         String?
  conversationId    String?
  direction         ConversationDirection
  sourceNumber      String
  destinationNumber String
  providerCallId    String?               @unique
  status            String
  startAt           DateTime?
  endAt             DateTime?
  durationSeconds   Int?
  forwarded         Boolean               @default(false)
  forwardingTarget  String?
  outcomeCode       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation      Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
}

model WorkflowExecutionRef {
  id           String                  @id @default(uuid())
  tenantId     String?
  workflowCode String
  executionRef String
  status       WorkflowExecutionStatus
  inputHash    String?
  resultJson   Json?
  startedAt    DateTime
  finishedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  tenant       Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([workflowCode, executionRef])
}

model AffiliateSettings {
  id                   String   @id @default("singleton")
  cookieDurationDays   Int      @default(30)
  commissionRatePct    Float    @default(20)
  commissionType       String   @default("PERCENTAGE")
  minPayoutCents       Int      @default(5000)
  autoApproveAfterDays Int      @default(30)
  programName          String   @default("Affiliate Program")
  programDescription   String   @default("Earn commission by referring new customers.")
  termsUrl             String?
  updatedAt            DateTime @updatedAt
}

model AffiliateAccount {
  id                     String          @id @default(uuid())
  userId                 String          @unique
  status                 AffiliateStatus @default(PENDING)
  referralCode           String          @unique
  stripeConnectAccountId String?         @unique
  payoutMethodJson       Json?
  taxProfileJson         Json?
  payoutRequestedAt      DateTime?
  totalEarnedCents       Int             @default(0)
  totalPaidCents         Int             @default(0)
  approvedAt             DateTime?
  // Soft-delete anchor (data-loss prevention). When set, the partner is
  // excluded from list / login / lookup queries but their record + history
  // remain. Used by admin "remove partner" actions instead of hard delete.
  // To purge for compliance reasons (GDPR / explicit request), a separate
  // admin-only hard-delete path is required.
  deletedAt              DateTime?
  notes                  String?
  // Partner's marketing voice intensity. Same scale as BusinessProfile.aggressionTier.
  // Drives AI-Assist generated pitch material + future per-partner Bunny-hosted assets.
  // See docs/marketing-style-guide.md for the spectrum definition.
  aggressionTier         String          @default("balanced")
  // Phase G.4 — partner onboarding wizard. Explicit per-step completion flags
  // ({ profile: true, ... }) that override the data-based auto-detection in
  // /api/partner/onboarding/status. Mirrors Tenant.onboardingMarkedDone.
  onboardingMarkedDone   Json?
  // Manual override to re-show the onboarding wizard after it auto-hid on
  // completion. Banner shows when wizard incomplete OR this is true.
  showOnboardingWizard   Boolean         @default(false)

  // ── Affiliate Agreement e-signature (immutable once accepted) ────────────
  // Set once when the partner checks the acknowledgement box, types their
  // legal name, and submits the Contract tab. Never cleared or overwritten —
  // the accept endpoint rejects a second submission. agreementVersion records
  // which revision of the terms they bound themselves to (audit trail).
  agreementAcceptedAt DateTime?
  agreementSignerName String?
  agreementVersion    String?
  agreementIpHash     String? // sha256(ip)[:16] — audit, not PII reveal

  // ── Marketing-page identity (Phase B Partner profile) ────────────────────
  // The slug is the partner's permanent public identifier. It drives both:
  //   1. URL routing — /p/<slug>/voice-1/  (their published partner pages)
  //   2. Email alias — <slug>@myorbisresults.com  (their personalized sending address)
  // Derived once at partner creation from firstName.lastName (with collision-handling
  // suffix: alex.rivera -> alex.rivera2). Immutable after first save so external
  // links and email threads don't break when a partner changes their display name.
  slug                      String? @unique
  avatarUrl                 String?
  displayName               String? // From-header label; null falls back to "First Last"
  bio                       String? // shown on partner pages as short author copy
  partnerPhone              String? // public-facing partner phone (distinct from User-level phone)
  businessName              String?
  // ── Partner public mailing address (Phase F.5) ───────────────────────────
  // Optional. Shown on partner pages and used as the CAN-SPAM postal address
  // in marketing email footers when the partner sends bulk campaigns. Free-
  // text fields — we don't enforce US-only or strict ZIP format, because
  // partners outside the US still need to identify their business location.
  // Empty string = unset (so `null` and `""` are interchangeable upstream).
  partnerStreet             String? // "716 Washington St"
  partnerUnit               String? // "Suite 2" / "Apt 4B" / "Floor 3"
  partnerCity               String? // "Allentown"
  partnerState              String? // "PA"  (or province / region outside US)
  partnerPostalCode         String? // "18102" (or "K1A 0B1" / "EC1A 1BB" / etc.)
  emailSignature            String? // appended to every outbound email composed by this partner
  calendarId                String? // Google Calendar ID for booking routing
  forwardPlatformEmails     Boolean @default(true) // copy inbound to user.email Gmail
  partnerPageActive         Boolean @default(false) // /p/<slug>/ pages live + Mailbox accessible
  // Phase E.10 — partner notification preferences. Each Boolean controls a
  // distinct partner-bound notification path. Set true by default — partners
  // opt-OUT of noise rather than opting in. Wire new notifications through
  // these flags so they respect the partner's stated preference.
  notifyAppointmentsEnabled Boolean @default(true) // email when an appointment books on their calendar

  // Phase E.12 — partner-side reminder preferences (mirror of E.6 on
  // BusinessProfile). When a booking is routed to this partner's calendar
  // (Appointment.partnerId set), the reminder runner reads these instead of
  // the tenant defaults. Lets partners run different SLAs from the platform.
  partnerReminderEnabled      Boolean @default(true)
  partnerReminderOffsetsMin   Int[]   @default([1440, 60]) // 24h + 1h before
  partnerReminderEmailEnabled Boolean @default(true)
  partnerReminderSmsEnabled   Boolean @default(true)

  // ── Phase E.3 — Partner booking preferences ──────────────────────────────
  // Controls when prospects can book the partner via the agent or the public
  // /p/<slug>/book page (E.4). Same shape as BusinessProfile.businessHoursJson:
  //   { mon: { open: "09:00", close: "17:00" }, tue: {...}, sun: null, ... }
  // A day omitted or set to null means "closed that day".
  bookingHoursJson       Json?
  // Default appointment length in minutes — used when the agent/booker
  // doesn't specify, and as the slot increment on the public booking page.
  bookingSlotDurationMin Int     @default(30)
  // Minimum lead time: a slot starting less than this many minutes from "now"
  // is hidden. Prevents same-minute bookings during a live conversation.
  bookingMinNoticeMin    Int     @default(60)
  // Maximum lookahead: slots more than this many days from "now" are hidden.
  bookingMaxAdvanceDays  Int     @default(60)
  // Buffer minutes inserted before / after each calendar busy block so the
  // partner gets breathing room between back-to-back appointments.
  bookingBufferBeforeMin Int     @default(0)
  bookingBufferAfterMin  Int     @default(0)
  // IANA timezone used to interpret bookingHoursJson "09:00" labels.
  // Falls back to user.preferredTimezone, then to America/New_York.
  bookingTimezone        String?

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks                  AffiliateClick[]
  conversions             AffiliateConversion[]
  commissions             AffiliateCommission[]
  payoutRequests          AffiliatePayoutRequest[]
  customLinks             AffiliateCustomLink[]
  // Per-partner Google Calendar OAuth (Phase E.0). The partner connects
  // their OWN Google account via /api/partner/integrations/google/connect;
  // OAuth tokens land in the linked IntegrationConnection. Used by the
  // partner-portal calendar view (E.1), the agent's book_appointment when
  // the widget runs on a partner page (E.2), and the public booking page (E.4).
  integrationConnectionId String?                  @unique
  integrationConnection   IntegrationConnection?   @relation("PartnerGoogle", fields: [integrationConnectionId], references: [id], onDelete: SetNull)

  emails         Email[]
  emailTemplates EmailTemplate[]

  // Phase E.2 back-relations — Conversations and Appointments that originated
  // from this partner's landing-page widget. partnerId is set on those rows
  // at session-start (Conversation) / booking-creation (Appointment).
  partnerConversations Conversation[] @relation("PartnerConversations")
  partnerAppointments  Appointment[]  @relation("PartnerAppointments")

  // Phase F.3 — partner-scoped CRM. Pipeline stages, contacts, and notes
  // owned by this partner. Independent of any tenant's CRM data.
  partnerContacts       Contact[]       @relation("PartnerContacts")
  partnerPipelineStages PipelineStage[] @relation("PartnerPipelineStages")
  partnerContactNotes   ContactNote[]   @relation("PartnerContactNotes")

  // Phase G.1 — partner-scoped Twilio. Each partner gets their own Twilio
  // subaccount + can own phone numbers + agent configs. Mirrors the tenant
  // surface so inbound voice/SMS can route to the partner's agent.
  twilioSubaccount     PartnerTwilioSubaccount?  @relation("PartnerTwilioSubaccount")
  partnerPhoneNumbers  PhoneNumber[]             @relation("PartnerPhoneNumbers")
  partnerAgentProfiles AgentProfile[]            @relation("PartnerAgentProfiles")
  stripeCustomer       PartnerStripeCustomerRef? @relation("PartnerStripeCustomer")

  // ── Phase G.2 — Partner SMS / MMS credit balance ─────────────────────────
  // Decimal (10,2) so MMS-at-2.5-credits doesn't accumulate FP error across
  // many sends. Credits roll over forever — never reset, never expire. Top-up
  // packs grant credits via Stripe one-time Checkout; each outbound message
  // deducts according to channel weight (SMS=1, long SMS=2/seg, MMS=2.5).
  smsCreditBalance Decimal                   @default(0) @db.Decimal(10, 2)
  smsCreditLedger  PartnerSmsCreditLedger[]  @relation("PartnerSmsCreditLedger")
  voiceUsageLedger PartnerVoiceUsageLedger[] @relation("PartnerVoiceUsage")

  // Phase G.2.1 — last time we emailed the partner about low credits OR
  // negative pack margin. Dedup window is 24h so we don't spam on every
  // send when balance is below threshold.
  smsCreditLowNotifiedAt DateTime?

  // ── Phase F.4 — Bulk email config + reputation tracking ─────────────────
  // ALL fields below are ADMIN-controlled. Partners see read-only summaries
  // ("you can send up to N/day in the 9am-5pm window"), but cannot edit. The
  // editing UI lives at /admin/email-policy and (per-partner) on the admin
  // partner detail page. Default values come from SystemConfig platform
  // policy so admin can move all partners' defaults at once.
  //
  // The schema fields below are per-partner OVERRIDES on top of those
  // platform defaults. Null on most fields means "inherit platform default."
  // Required boolean fields (emailBulkEnabled, emailBulkSuspended) are
  // explicit per-partner state.
  emailBulkEnabled         Boolean   @default(false) // master gate — admin flips ON after review
  emailBulkSuspendedAt     DateTime? // manual or auto suspension (bounce/complaint threshold)
  emailBulkSuspendedReason String?
  emailLastBulkWarningAt   DateTime? // tracks last "approaching threshold" warning so we dedupe
  // Per-partner overrides (null = inherit platform default from SystemConfig)
  emailDailyCap            Int?
  emailSendWindowStartHour Int?
  emailSendWindowEndHour   Int?
  emailDripIntervalSecs    Int?

  // Lead engine — remaining lead-search credits. ~1 credit per result
  // returned. Default is a trial allotment; admin can top up. Decremented
  // when a search is submitted.
  leadSearchCredits Int @default(250)

  partnerMessageLogs       MessageLog[]                   @relation("PartnerMessageLogs")
  partnerEmailSuppressions EmailSuppression[]             @relation("PartnerEmailSuppressions")
  partnerEmailCampaigns    EmailCampaign[]                @relation("PartnerEmailCampaigns")
  a2pApplication           TenantA2PApplication?
  leadSearches             LeadSearch[]
  leads                    Lead[]
  sendingDomains           PartnerSendingDomain[]
  coldEmailSends           ColdEmailSend[]
  coldEmailCampaigns       ColdEmailCampaign[]
  gmbEvaluations           GmbEvaluation[]
  // Webinar Marketing (partner-scoped lead-discovery + invite list system)
  webinarLists             WebinarLeadList[]              @relation("PartnerWebinarLists")
  webinarContacts          WebinarInviteContact[]         @relation("PartnerWebinarContacts")
  webinarSuppressions      WebinarSuppression[]           @relation("PartnerWebinarSuppressions")
  // Daily Activity playbook tracker (Market Vault → Daily Activity tab)
  dailyActivities          PartnerDailyActivityProgress[] @relation("PartnerDailyActivities")
  // Partner script library (Directory Leads → Scripts tab). Per-partner scripts;
  // admin defaults live as ownerless rows (affiliateAccountId null, isDefault true).
  partnerScripts           PartnerScript[]                @relation("PartnerScripts")

  // ── Commission structure (locked at signup, admin-overridable) ───────────
  // A new partner snapshots Tier 1's recurringPct onto commissionRatePct at
  // signup — that frozen rate is theirs for life. Editing a CommissionTier
  // later only affects FUTURE signups, not anyone already locked. Admin can
  // re-assign a partner to another tier (re-snapshots that tier's current
  // rate) or set a fully custom rate (commissionTierId → null).
  //   commissionTierId   — which tier they're on (reference/label); null = custom override
  //   commissionRatePct  — the FROZEN recurring % used by recordConversion;
  //                        null = legacy partner, falls back to AffiliateSettings.commissionRatePct
  //   commissionLockedAt — when the rate was last snapshotted/overridden (audit)
  commissionTierId   String?
  commissionRatePct  Float?
  commissionLockedAt DateTime?
  commissionTier     CommissionTier? @relation(fields: [commissionTierId], references: [id], onDelete: SetNull)
}

// Partner script library (Directory Leads → Scripts tab). A script is either:
//   • a partner's OWN script  (affiliateAccountId set, isDefault false) — full CRUD by that partner
//   • an admin DEFAULT template (affiliateAccountId null, isDefault true) — global, read-only to
//     partners, managed in the admin dashboard. Partners COPY a default into a new own script.
// bodyHtml is rich text, sanitized server-side on write (allowlist) before storage.
model PartnerScript {
  id                 String            @id @default(uuid())
  affiliateAccountId String?
  affiliateAccount   AffiliateAccount? @relation("PartnerScripts", fields: [affiliateAccountId], references: [id], onDelete: Cascade)
  isDefault          Boolean           @default(false)
  title              String
  channel            String            @default("call") // call | email | sms
  bodyHtml           String            // sanitized rich-text HTML
  sourceDefaultId    String? // if copied from an admin default, which one (provenance)
  createdByUserId    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([affiliateAccountId])
  @@index([isDefault])
}

// Admin-customizable commission tiers. Exactly three rows in practice
// (level 1/2/3), seeded on first read. A new partner locks to level 1 at
// signup. recurringPct is the % of each subscription payment the partner
// earns EVERY billing cycle the referred customer keeps paying (lifetime
// recurring). name is an admin-editable label (e.g. "Standard"/"Silver"/
// "Gold"). Editing a tier never retroactively changes locked partners —
// see AffiliateAccount.commissionRatePct for the freeze semantics.
model CommissionTier {
  id           String             @id @default(uuid())
  level        Int                @unique // 1 = signup default, ascending
  name         String
  recurringPct Float
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  partners     AffiliateAccount[]
}

/// GMB Evaluation — a partner's lead-gen audit of a prospect's Google Business
/// Profile. Read-only door-opener: the partner enters a prospect business, the
/// gmb-audit engine fetches public GBP data (via Serper.dev) and scores it, and
/// the partner exports a brand-parameterized report to pitch the trifecta. The
/// GBP-audit engine is portable — same logic later powers MyOrbisLocal Phase A.
model GmbEvaluation {
  id           String           @id @default(uuid())
  partnerId    String
  businessName String
  city         String
  website      String?
  /// Comma-free target keywords the partner wanted ranking checked for. Stored
  /// so the report and any re-run use the same inputs.
  keywords     String[]         @default([])
  overallScore Int              @default(0)
  /// Full typed AuditResult: per-dimension scores + findings + ranked gaps.
  result       Json
  /// Raw provider payload (Serper response) so the report re-renders without
  /// spending another Serper query.
  rawPayload   Json?
  /// Soft delete. A partner can hide an evaluation from their list, but the row
  /// is retained so it still counts toward the monthly cap (delete never frees
  /// a slot — bounds Serper spend).
  deletedAt    DateTime?
  /// Unguessable token for the public, customer-facing shareable report link
  /// (app.myorbisvoice.com/r/<token>). Generated on create; no auth needed to
  /// view, so the token IS the access control.
  shareToken   String?          @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  partner      AffiliateAccount @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
}

/// Lead engine — a partner's business-discovery search. Drives the Search
/// History view. The scraping + enrichment runs in the leadengine service;
/// externalJobId links this row to that job.
model LeadSearch {
  id            String           @id @default(uuid())
  partnerId     String
  industry      String
  location      String
  resultCount   Int // requested result count
  status        LeadSearchStatus @default(PENDING)
  externalJobId String? // leadengine job id
  leadCount     Int              @default(0)
  emailCount    Int              @default(0)
  errorReason   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  partner       AffiliateAccount @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  leads         Lead[]

  @@index([partnerId, createdAt])
}

/// Lead engine — one enriched business from a search. Staging only: raw and
/// partner-reviewed. An accepted lead is promoted into a Contact in the CRM
/// "New Lead" stage (promotedContactId links the two). A scraped lead has
/// consented to nothing — the promote path marks the Contact's source SCRAPED
/// and born-opted-out of voice + SMS; cold email is the only allowed channel.
model Lead {
  id                String                  @id @default(uuid())
  searchId          String
  partnerId         String
  businessName      String
  ownerName         String?
  ownerTitle        String? // "Owner", "President", etc. — best-effort from the site
  email             String?
  phone             String?
  website           String?
  address           String?
  latitude          Float? // from the Maps source — drives the Route Planner
  longitude         Float?
  rating            Float?
  reviewCount       Int?
  mapRank           Int? // position in the Google Maps results for the search query
  category          String?
  socialsJson       Json?
  score             Int                     @default(0)
  reviewStatus      LeadReviewStatus        @default(NEW)
  promotedContactId String? // set when the lead is promoted to a Contact
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  search            LeadSearch              @relation(fields: [searchId], references: [id], onDelete: Cascade)
  partner           AffiliateAccount        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  campaignLeads     ColdEmailCampaignLead[]

  @@index([partnerId, reviewStatus])
  @@index([searchId])
}

enum LeadSearchStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum LeadReviewStatus {
  NEW
  SAVED
  REJECTED
  PROMOTED
}

/// Bulk Email — a partner's dedicated cold-email sending domain. One .com per
/// partner who opts in, giving each true sending-reputation isolation: one
/// partner's spam complaints can never touch another's. Provisioned through
/// the platform's master Cloudflare account (registrar + DNS) and verified as
/// an Amazon SES domain identity. The partner pays for the domain before
/// provisioning runs. A new row is created per attempt; the service enforces
/// at most one non-FAILED domain per partner.
model PartnerSendingDomain {
  id        String              @id @default(uuid())
  partnerId String
  domain    String              @unique // the registered .com
  status    SendingDomainStatus @default(PENDING_PAYMENT)

  // Billing — partner pays for the domain before provisioning runs
  stripePaymentIntentId String?
  paidAt                DateTime?
  priceCents            Int? // what the partner was charged

  // Cloudflare — registrar + DNS zone
  cloudflareZoneId  String?
  registrarOrderRef String? // registrar registration reference
  dnsConfiguredAt   DateTime? // SPF/DKIM/DMARC written into the zone

  // Amazon SES — domain identity + DKIM verification
  sesDkimTokensJson Json? // the 3 DKIM CNAME tokens SES issues for the domain
  sesVerifiedAt     DateTime? // SES reports the domain identity verified

  // Warmup — gentle ramp from a low daily cap up to the full 50/day
  warmupStartedAt   DateTime?
  warmupDayCap      Int       @default(5) // current day's cap while ramping
  warmupCompletedAt DateTime?

  verified  Boolean  @default(false)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner AffiliateAccount @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
}

enum SendingDomainStatus {
  PENDING_PAYMENT // wizard step 1 — partner picked a name, not yet paid
  REGISTERING // paid; Cloudflare registering the .com
  DNS_PENDING // registered; writing SPF/DKIM/DMARC
  VERIFYING // DNS written; waiting on SES identity verification
  WARMING // verified; warmup runner ramping the cap
  ACTIVE // warmup complete; full daily cap available
  FAILED // provisioning error — see lastError
}

/// Bulk Email — one cold-email send. The send log: powers the per-partner
/// daily-cap count, the unsubscribe-token lookup (CAN-SPAM), and bounce /
/// complaint reconciliation from SES webhooks. Partner-scoped — cold email is
/// never tenant-scoped; it goes out on the partner's own sending domain.
model ColdEmailSend {
  id               String              @id @default(uuid())
  partnerId        String
  sendingDomainId  String // PartnerSendingDomain used for this send
  campaignLeadId   String? // set when the send is a campaign touch (Phase 5 attribution)
  toEmail          String
  fromEmail        String
  subject          String
  status           ColdEmailSendStatus @default(QUEUED)
  unsubscribeToken String              @unique // per-send public token — unsubscribe + click links
  sesMessageId     String? // SES message id — links webhook events back to this row
  failureReason    String? // why it was not sent, or why SES rejected it
  sentAt           DateTime?
  clickedAt        DateTime? // when the recipient clicked the booking CTA
  bouncedAt        DateTime?
  complainedAt     DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  partner AffiliateAccount @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, sentAt])
  @@index([partnerId, status])
}

enum ColdEmailSendStatus {
  QUEUED // created, not yet handed to SES
  SENT // accepted by SES
  SUPPRESSED // recipient on the suppression list — not sent
  INVALID // Reoon flagged the address — not sent
  BLOCKED // cap / send window / drip / policy / no active domain — not sent
  FAILED // SES rejected the send
  BOUNCED // hard bounce reported by an SES webhook
  COMPLAINED // spam complaint reported by an SES webhook
}

/// Bulk Email Phase 3 — a multi-touch cold-email campaign. A partner picks
/// accepted leads and builds a touch sequence (touch 1 = the AI intro, then
/// timed follow-ups). Phase 4's sequencer advances each enrolled lead through
/// the touches, respecting the partner's cap / send window / drip.
model ColdEmailCampaign {
  id          String                  @id @default(uuid())
  partnerId   String
  name        String
  status      ColdEmailCampaignStatus @default(DRAFT)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  partner AffiliateAccount         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  touches ColdEmailCampaignTouch[]
  leads   ColdEmailCampaignLead[]

  @@index([partnerId, status])
}

/// One step in a campaign's touch sequence. Ordered by touchNumber; sent
/// delayDays after the previous touch (touch 1: delayDays after enrollment).
model ColdEmailCampaignTouch {
  id          String   @id @default(uuid())
  campaignId  String
  touchNumber Int // 1 = intro, 2+ = follow-ups
  delayDays   Int      @default(0) // days to wait before this touch
  subject     String
  bodyHtml    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign ColdEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, touchNumber])
  @@index([campaignId])
}

/// A lead enrolled in a campaign. Carries the per-lead sequence progress that
/// Phase 4's sequencer advances. Created at ENROLLED in Phase 3.
model ColdEmailCampaignLead {
  id           String                      @id @default(uuid())
  campaignId   String
  leadId       String
  status       ColdEmailCampaignLeadStatus @default(ENROLLED)
  currentTouch Int                         @default(0) // last touch sent; 0 = none yet
  nextTouchAt  DateTime? // when the sequencer should act next
  clickedAt    DateTime? // first time this lead clicked a booking CTA
  bookedAt     DateTime? // when this lead booked — the funnel conversion
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  campaign ColdEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@index([status, nextTouchAt])
}

enum ColdEmailCampaignStatus {
  DRAFT // being built — not sending
  ACTIVE // running — the sequencer is processing it
  PAUSED // partner-paused or auto-paused
  COMPLETED // every enrolled lead finished the sequence
  ARCHIVED
}

enum ColdEmailCampaignLeadStatus {
  ENROLLED // in the campaign, sequence not started
  IN_PROGRESS // mid-sequence
  REPLIED // lead replied — sequence stopped
  BOOKED // lead booked — the win
  COMPLETED // finished all touches, no reply
  STOPPED // unsubscribed / bounced / removed
}

/// Partner-scoped email storage powering the Mailbox UI in /partner.
/// Every inbound message to a partner alias (e.g. alex.rivera@myorbisresults.com)
/// and every outbound message sent through sendPartnerEmail() lands here.
/// Threading uses RFC 5322 Message-ID / In-Reply-To when present, falling back
/// to a heuristic thread group (same partner + normalized subject + last 14 days).
/// Reusable email templates for the partner Mailbox Compose flow.
/// Two flavors:
///   - System templates (partnerId NULL): seeded by the platform, available to every partner.
///     Standard library: "Follow-up after missed call", "Thank you for booking", etc.
///   - Partner-owned (partnerId set): a partner's custom template, only they can see/edit it.
///
/// Variable substitution happens client-side at insert time. Supported tokens:
///   {{partner.firstName}}     - partner's first name
///   {{partner.displayName}}   - partner's display name (e.g. "Alex Rivera")
///   {{partner.businessName}}  - partner's business
///   {{partner.signature}}     - partner's email signature
///   {{partner.partnerEmail}}  - partner's alias (e.g. alex.rivera@myorbisresults.com)
///   {{prospect.firstName}}    - left as-is if not known; partner fills in before sending
///   {{prospect.businessName}} - same
model EmailTemplate {
  id          String            @id @default(uuid())
  partnerId   String? // null = system template available to all partners
  category    String // followup | thankyou | callback | reengagement | intro | custom
  name        String // shown in the picker dropdown
  description String? // one-line help text
  subject     String // may contain {{variables}}
  bodyHtml    String // may contain {{variables}}
  isSystem    Boolean           @default(false) // true for platform-seeded library entries
  sortOrder   Int               @default(100)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  partner     AffiliateAccount? @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, sortOrder])
  @@index([isSystem, sortOrder])
}

model Email {
  id              String           @id @default(uuid())
  partnerId       String
  threadId        String?
  messageId       String?          @unique
  inReplyTo       String?
  direction       MessageDirection
  fromAddress     String
  toAddresses     Json
  ccAddresses     Json?
  bccAddresses    Json?
  subject         String
  htmlBody        String?
  textBody        String?
  attachmentsJson Json?
  deliveryStatus  String?
  readAt          DateTime?
  receivedAt      DateTime?
  sentAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  partner         AffiliateAccount @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, direction, createdAt])
  @@index([partnerId, threadId])
}

model AffiliateCustomLink {
  id                 String           @id @default(uuid())
  affiliateAccountId String
  slug               String           @unique
  label              String
  notes              String?
  archivedAt         DateTime?
