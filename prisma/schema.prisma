  ownerType       SecretOwnerType
  ownerId         String
  secretType      String
  label           String
  provider        String
  externalRef     String?
  lastValidatedAt DateTime?
  rotationStatus  RotationStatus  @default(UNKNOWN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

