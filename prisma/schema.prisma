  cookieDurationDays   Int      @default(30)
  commissionRatePct    Float    @default(20)
  commissionType       String   @default("PERCENTAGE")
  minPayoutCents       Int      @default(5000)
  autoApproveAfterDays Int      @default(30)
  programName          String   @default("Affiliate Program")
  programDescription   String   @default("Earn commission by referring new customers.")
  termsUrl             String?
  updatedAt            DateTime @updatedAt
}

model AffiliateAccount {
  id                     String                   @id @default(uuid())
  userId                 String                   @unique
  status                 AffiliateStatus          @default(PENDING)
  referralCode           String                   @unique
  stripeConnectAccountId String?                  @unique
  payoutMethodJson       Json?
  taxProfileJson         Json?
