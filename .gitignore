# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
.turbo/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# Prisma
prisma/migrations/dev.db

# Editor & agent tools
.vscode/settings.json
.idea/
*.swp
.claude/

# Credentials (never commit)
.netrc
*.netrc
*.coreftp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Docker volumes (never commit)
postgres_data/
redis_data/
n8n_data/
backups/
site/Site.zip
*.dump
snapshots/
.gstack/

# /graphify analysis output (graph.html / graph.json / GRAPH_REPORT.md / cache).
# Regenerable from source any time via /graphify — never commit the artifacts.
graphify-out/

# CodeGraph local index (SQLite DB + cache). Machine-local, regenerable via
# `codegraph index`. Never commit — see .codegraph/.gitignore for inner rules.
.codegraph/
# CodeGraph MCP registration — personal agent tooling, requires the `codegraph`
# binary + a local index on each machine. Keep local until the team standardizes
# on it (then commit + document `codegraph install` as a setup step).
.mcp.json

# Local source-media folder (uploaded to Bunny, not tracked)
Videos/

# Transient scratch dirs — recording pulls, raw audio captures, resampler WAVs.
# Regenerable via infrastructure/scripts/pull-twilio-recordings.sh; never commit
# (contains private call audio).
tmp/
apps/api/tmp/

# Local scratch / reference material folder (screen-capture PDFs, working assets).
Resources/

# Per-machine wiki binding marker (gmb-audit). Machine-local, not shared state.
.wiki-link

# Local third-party reference PDF (copyrighted — never commit).
pdfcoffee.com-*.pdf

# One-off local HTML backups of the marketing index (kept locally, not tracked).
site/index.legacy.html
site/index.shell-backup.html

# Render video artifacts — store on CDN, never in git (GitHub 100MB/file limit)
apps/render/out/
apps/render/public/source/*.mp4
