# MyOrbis Account Hub (Keycloak) — env template.
# Real values live ONLY in /opt/myorbis-id/.env.prod on box #1 (mode 600),
# generated by deploy-keycloak-box1.sh. NEVER commit real secrets.

# Postgres password for the Keycloak DB user (also used as KC_DB_PASSWORD).
POSTGRES_PASSWORD=__generate_openssl_rand_hex_24__

# Temporary bootstrap admin (use it once to create a real admin, then disable).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=__generate_openssl_rand_hex_24__
